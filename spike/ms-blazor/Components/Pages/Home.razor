@page "/"

<PageTitle>Spike Smoke Test</PageTitle>

<h1>Telerik Smoke Test</h1>

<TelerikButton OnClick="@(() => DialogVisible = true)">Open Command Preview</TelerikButton>

<TelerikDialog @bind-Visible="@DialogVisible" Title="AI Command Preview — Human Review Required" Width="520px">
    <DialogContent>
        <p>The assistant generated this safe command. Nothing changes until you approve.</p>
        <pre style="background:#f5f5f5;padding:10px;border-radius:6px">{ "action": "filterGrid", "field": "confidence", "value": "High" }</pre>
    </DialogContent>
    <DialogButtons>
        <TelerikButton OnClick="@(() => { Result = "Approved"; DialogVisible = false; })">Approve</TelerikButton>
        <TelerikButton OnClick="@(() => { Result = "Rejected"; DialogVisible = false; })">Reject</TelerikButton>
    </DialogButtons>
</TelerikDialog>

@if (Result is not null)
{
    <p id="decision-result">Decision: @Result</p>
}

@code {
    private bool DialogVisible;
    private string? Result;
}

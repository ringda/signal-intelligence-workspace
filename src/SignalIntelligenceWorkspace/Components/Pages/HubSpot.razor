@page "/hubspot"
@inject HubSpotCrmService HubSpotData
@inject HubSpotWorkflowEngine WorkflowEngine
@inject HubSpotAssistantAiService HubSpotAssistant
@inject IStringLocalizer<Ui> L
@using System.Globalization
@using System.Text

<PageTitle>@L["Nav.HubSpot"] | @L["App.Name"]</PageTitle>

<div class="hubspot-page hubspot-quality-page">
    <div class="hubspot-quality-hero">
        <div>
            <div class="hubspot-kicker">AI-Governed CRM Handoff Quality</div>
            <h2>Today&apos;s HubSpot handoff review</h2>
            <p>
                Find the CRM records that should not move to follow-up yet, turn the safe ones into reviewable
                next-action drafts, and keep every writeback behind a policy gate.
            </p>
        </div>

        @if (WorkflowRun is not null)
        {
            <div class="hubspot-quality-status" data-testid="hubspot-quality-status">
                <span>Current feel</span>
                <strong>@WorkflowRun.Quality.StatusLabel</strong>
                <small>@WorkflowRun.Quality.StatusDetail</small>
            </div>
        }
    </div>

    <section class="hubspot-use-case-panel" data-testid="hubspot-use-case">
        <div>
            <span>Use this page to answer</span>
            <strong>What should a GTM operator review before touching HubSpot?</strong>
        </div>
        <ol>
            <li>Spot records that block clean handoff: missing owner, weak lifecycle, stale deal timing.</li>
            <li>Inspect the agent proposal and the evidence it used.</li>
            <li>Approve, reject, or rewrite the next action outside HubSpot before any CRM update exists.</li>
        </ol>
    </section>

    @if (LoadError is not null)
    {
        <div class="cockpit-alert">@LoadError</div>
    }
    else if (Snapshot is null || WorkflowRun is null)
    {
        <div class="hubspot-loading-panel">
            <strong>Loading live HubSpot records into the workflow engine...</strong>
            <span>Expected output: records scanned, proposal queue, selected case evidence, policy decisions, and source records.</span>
        </div>
    }
    else
    {
        <section class="hubspot-next-move" data-testid="hubspot-next-move">
            <div>
                <span>Operator next move</span>
                <strong>@NextMoveTitle</strong>
                <small>@NextMoveDetail</small>
            </div>
            @if (SelectedProposal is not null)
            {
                <button type="button" class="hubspot-jump-button" @onclick="@(() => SelectProposal(SelectedProposal))">
                    Review selected case
                </button>
            }
        </section>

        <div class="hubspot-action-row">
            <a class="hubspot-link-button" href="@Snapshot.PortalUrl" target="_blank" rel="noreferrer">
                Open HubSpot portal
            </a>
            <span class="hubspot-policy">Read-only API. Proposal-only workflow. No HubSpot write executed.</span>
        </div>

        <section class="hubspot-truth-panel">
            <strong>What is real here</strong>
            <span>
                Contacts, companies, deals, and owners are fetched from the connected HubSpot portal.
                Workflow rules, policies, proposals, and audit events are versioned in this repo so they can be shared,
                tested, and reviewed outside any one local Codex or Claude skill.
            </span>
        </section>

        <section class="hubspot-quality-grid" aria-label="HubSpot workflow quality metrics">
            <div class="hubspot-quality-tile">
                <span>Records scanned</span>
                <strong>@WorkflowRun.Quality.RecordsScanned</strong>
                <small>HubSpot source rows</small>
            </div>
            <div class="hubspot-quality-tile hubspot-quality-good">
                <span>Actionable</span>
                <strong>@WorkflowRun.Quality.ActionableProposals</strong>
                <small>safe draft proposals</small>
            </div>
            <div class="hubspot-quality-tile hubspot-quality-watch">
                <span>Need review</span>
                <strong>@WorkflowRun.Quality.NeedsHumanReview</strong>
                <small>human CRM truth required</small>
            </div>
            <div class="hubspot-quality-tile hubspot-quality-blocked">
                <span>Blocked</span>
                <strong>@WorkflowRun.Quality.BlockedProposals</strong>
                <small>policy stopped writeback</small>
            </div>
            <div class="hubspot-quality-tile">
                <span>Unsafe writes</span>
                <strong>@WorkflowRun.Quality.UnsafeWrites</strong>
                <small>must stay zero</small>
            </div>
        </section>

        <section class="hubspot-review-layout" data-testid="hubspot-proposal-review">
            <div class="hubspot-panel hubspot-proposal-queue">
                <div class="cockpit-section-head">
                    <div>
                        <h3>Proposal Review Queue</h3>
                        <p class="muted">This is the working list: review these before creating tasks, notes, or field updates in HubSpot.</p>
                    </div>
                </div>

                @if (WorkflowRun.Proposals.Count == 0)
                {
                    <div class="cockpit-empty">No proposals were generated from this HubSpot snapshot.</div>
                }
                else
                {
                    @foreach (var group in ProposalGroups)
                    {
                        <div class="hubspot-proposal-group">
                            <div class="hubspot-proposal-group-title">
                                <span>@group.Label</span>
                                <strong>@group.Proposals.Count</strong>
                            </div>
                            @foreach (var proposal in group.Proposals)
                            {
                                <button type="button"
                                        class="hubspot-proposal-button @(SelectedProposal?.Id == proposal.Id ? "is-selected" : string.Empty)"
                                        data-testid="hubspot-proposal-button"
                                        @onclick="@(() => SelectProposal(proposal))">
                                    <span class="cockpit-pill @PriorityClass(proposal.Priority)">@proposal.Policy.Label</span>
                                    <strong>@proposal.Title</strong>
                                    <small>@proposal.EvidenceSummary</small>
                                    <em>@UseCaseFor(proposal)</em>
                                </button>
                            }
                        </div>
                    }
                }
            </div>

            <div class="hubspot-panel hubspot-case-detail" data-testid="hubspot-selected-case">
                @if (SelectedProposal is null)
                {
                    <div class="cockpit-empty">Select a proposal to inspect evidence and policy.</div>
                }
                else
                {
                    <div class="hubspot-case-head">
                        <div>
                            <span>@SelectedProposal.ObjectType.ToUpperInvariant() · @SelectedProposal.Kind</span>
                            <h3>@SelectedProposal.RecordName</h3>
                        </div>
                        <span class="cockpit-pill @PriorityClass(SelectedProposal.Priority)">@SelectedProposal.Policy.Label</span>
                    </div>

                    <p class="hubspot-case-summary">@SelectedProposal.Summary</p>

                    <div class="hubspot-case-section">
                        <small>Why this matters</small>
                        <p>@UseCaseFor(SelectedProposal)</p>
                    </div>

                    <div class="hubspot-case-section">
                        <small>Evidence</small>
                        <ul>
                            @foreach (var evidence in SelectedProposal.Evidence)
                            {
                                <li>@evidence</li>
                            }
                        </ul>
                    </div>

                    <div class="hubspot-case-section">
                        <small>Recommended operator action</small>
                        <p>@SelectedProposal.ProposedAction</p>
                    </div>

                    <div class="hubspot-case-section hubspot-policy-box">
                        <small>Policy decision</small>
                        <strong>@SelectedProposal.Policy.Label</strong>
                        <p>@SelectedProposal.Policy.Reason</p>
                    </div>

                    <pre class="hubspot-note">@SelectedProposal.SuggestedNoteBody</pre>

                    <a class="hubspot-record-link" href="@SelectedProposal.HubSpotUrl" target="_blank" rel="noreferrer">
                        Open source record
                    </a>
                }
            </div>
        </section>

        <section class="hubspot-panel" data-testid="hubspot-representative-cases">
            <div class="cockpit-section-head">
                <div>
                    <h3>Representative Cases</h3>
                    <p class="muted">A quick feel for what the agent got right, what needs judgment, and what policy stopped.</p>
                </div>
            </div>

            <div class="hubspot-representative-grid">
                @foreach (var proposal in RepresentativeCases)
                {
                    <button type="button"
                            class="hubspot-representative-case"
                            @onclick="@(() => SelectProposal(proposal))">
                        <span class="cockpit-pill @PriorityClass(proposal.Priority)">@proposal.Priority</span>
                        <strong>@proposal.Title</strong>
                        <small>@proposal.EvidenceSummary</small>
                        <em>@UseCaseFor(proposal)</em>
                    </button>
                }
            </div>
        </section>

        <section class="hubspot-panel hubspot-assistant-panel" data-testid="hubspot-assistant">
            <div class="cockpit-assistant-header">
                <div class="cockpit-assistant-title">
                    <TelerikSvgIcon Icon="@SvgIcon.Sparkles" />
                    <h3>HubSpot CRM Assistant</h3>
                </div>
                <TelerikButton OnClick="@ClearAssistantChat"
                               Size="@ThemeConstants.Button.Size.Small"
                               FillMode="@ThemeConstants.Button.FillMode.Flat"
                               Enabled="@(!IsAssistantResponding)">
                    Clear
                </TelerikButton>
            </div>

            <div class="cockpit-assistant-context">
                Ask Gemini about the current workflow run: @WorkflowRun.Proposals.Count proposals,
                @WorkflowRun.Quality.NeedsHumanReview human-review cases, @WorkflowRun.Quality.BlockedProposals blocked actions.
                It can draft analysis and memos, but this page does not write to HubSpot.
            </div>

            <div class="cockpit-assistant-suggestions">
                @foreach (var suggestion in AssistantSuggestions)
                {
                    <button type="button"
                            class="cockpit-assistant-chip"
                            data-testid="@suggestion.TestId"
                            disabled="@IsAssistantResponding"
                            @onclick="@(() => ApplyAssistantSuggestionAsync(suggestion.Label))">
                        @suggestion.Label
                    </button>
                }
            </div>

            @if (!HubSpotAssistant.IsConfigured)
            {
                <div class="cockpit-assistant-status cockpit-assistant-status-error">
                    Gemini key is not configured for the HubSpot assistant.
                </div>
            }
            else if (IsAssistantResponding)
            {
                <div class="cockpit-assistant-status">
                    @HubSpotAssistant.ProviderName is reading the current workflow run...
                </div>
            }

            <div class="cockpit-assistant-chat">
                <TelerikChat TItem="AssistantChatMessage"
                             @ref="@AssistantChatRef"
                             Data="@AssistantMessages"
                             AuthorId="@AssistantUserId"
                             OnSendMessage="@OnAssistantSendMessageAsync"
                             Height="420px"
                             Width="100%">
                </TelerikChat>
            </div>
        </section>

        <section class="hubspot-panel" data-testid="hubspot-audit-events">
            <div class="cockpit-section-head">
                <div>
                    <h3>Workflow Audit Trail</h3>
                    <p class="muted">Generated locally from the shared workflow engine; newest events appear first.</p>
                </div>
            </div>
            <div class="hubspot-audit-list">
                @foreach (var audit in WorkflowRun.AuditEvents.Take(8))
                {
                    <div class="hubspot-audit-row">
                        <span>@audit.Id</span>
                        <strong>@audit.Decision</strong>
                        <small>@audit.Reason</small>
                    </div>
                }
            </div>
        </section>

        <section class="hubspot-source-records" data-testid="hubspot-source-records">
            <div class="cockpit-section-head">
                <div>
                    <h3>Source Records</h3>
                    <p class="muted">Raw read-only HubSpot evidence used by the workflow engine.</p>
                </div>
            </div>

            <div class="hubspot-grid-stack">
                @foreach (var section in Snapshot.Sections)
                {
                    <section class="hubspot-panel">
                        <div class="cockpit-section-head">
                            <div>
                                <h3>@section.Title</h3>
                                <p class="muted">@section.Subtitle</p>
                            </div>
                            <a class="hubspot-record-link" href="@section.IndexUrl" target="_blank" rel="noreferrer">
                                View in HubSpot
                            </a>
                        </div>

                        @if (section.Error is not null)
                        {
                            <div class="cockpit-alert">@section.Error</div>
                        }
                        else if (section.Rows.Count == 0)
                        {
                            <div class="cockpit-empty">No records returned by HubSpot.</div>
                        }
                        else
                        {
                            <TelerikGrid Data="@section.Rows"
                                         Sortable="true"
                                         FilterMode="@GridFilterMode.FilterMenu"
                                         Pageable="true"
                                         PageSize="5">
                                <GridColumns>
                                    <GridColumn Field="@nameof(HubSpotCrmRow.Primary)" Title="Name" Width="220px" />
                                    <GridColumn Field="@nameof(HubSpotCrmRow.Secondary)" Title="Secondary" Width="220px" />
                                    <GridColumn Field="@nameof(HubSpotCrmRow.Status)" Title="Status" Width="170px">
                                        <Template>
                                            @{
                                                var row = (HubSpotCrmRow)context;
                                            }
                                            <span class="cockpit-pill cockpit-pill-neutral">@row.Status</span>
                                        </Template>
                                    </GridColumn>
                                    <GridColumn Field="@nameof(HubSpotCrmRow.Detail)" Title="Detail" />
                                    <GridColumn Field="@nameof(HubSpotCrmRow.UpdatedAt)" Title="Updated" Width="140px" />
                                    <GridColumn Title="Record" Width="110px">
                                        <Template>
                                            @{
                                                var row = (HubSpotCrmRow)context;
                                            }
                                            <a class="hubspot-record-link" href="@row.HubSpotUrl" target="_blank" rel="noreferrer">
                                                Open
                                            </a>
                                        </Template>
                                    </GridColumn>
                                </GridColumns>
                            </TelerikGrid>
                        }
                    </section>
                }
            </div>
        </section>
    }
</div>

@code {
    private HubSpotCrmSnapshot? Snapshot { get; set; }
    private HubSpotWorkflowRun? WorkflowRun { get; set; }
    private HubSpotActionProposal? SelectedProposal { get; set; }
    private string? LoadError { get; set; }
    private TelerikChat<AssistantChatMessage>? AssistantChatRef { get; set; }
    private List<AssistantChatMessage> AssistantMessages { get; set; } = [];
    private bool IsAssistantResponding { get; set; }

    private const string AssistantUserId = "hubspot-user";
    private const string AssistantBotId = "hubspot-assistant";

    private static readonly IReadOnlyList<AssistantSuggestion> AssistantSuggestions =
    [
        new("Audit workflow quality risks", "hubspot-assistant-suggestion-quality"),
        new("Which proposals need human review first?", "hubspot-assistant-suggestion-review"),
        new("Draft a next-touch memo", "hubspot-assistant-suggestion-memo"),
        new("List blocked writeback proposals only", "hubspot-assistant-suggestion-blocked"),
    ];

    private IReadOnlyList<ProposalGroup> ProposalGroups =>
        WorkflowRun is null
            ? []
            :
            [
                new("Good", WorkflowRun.Proposals.Where(p => p.Priority == HubSpotProposalPriority.Good).ToList()),
                new("Unclear", WorkflowRun.Proposals.Where(p => p.Priority == HubSpotProposalPriority.Unclear).ToList()),
                new("Blocked", WorkflowRun.Proposals.Where(p => p.Priority == HubSpotProposalPriority.Blocked).ToList()),
            ];

    private IReadOnlyList<HubSpotActionProposal> RepresentativeCases =>
        WorkflowRun?.Proposals
            .GroupBy(proposal => proposal.Priority)
            .OrderBy(group => group.Key)
            .Select(group => group.First())
            .ToList() ?? [];

    private string NextMoveTitle
    {
        get
        {
            if (WorkflowRun is null || WorkflowRun.Proposals.Count == 0)
            {
                return "No CRM handoff action is ready from this snapshot";
            }

            if (WorkflowRun.Quality.BlockedProposals > 0)
            {
                return "Start with blocked handoffs";
            }

            if (WorkflowRun.Quality.NeedsHumanReview > 0)
            {
                return "Resolve unclear CRM truth before follow-up";
            }

            return "Review safe next-touch drafts";
        }
    }

    private string NextMoveDetail
    {
        get
        {
            if (WorkflowRun is null || WorkflowRun.Proposals.Count == 0)
            {
                return "The page still shows source records, but the agent did not find a useful handoff proposal.";
            }

            return $"{WorkflowRun.Quality.BlockedProposals} blocked, {WorkflowRun.Quality.NeedsHumanReview} need human review, {WorkflowRun.Quality.ActionableProposals} safe for draft review.";
        }
    }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            Snapshot = await HubSpotData.GetSnapshotAsync();
            WorkflowRun = WorkflowEngine.Run(Snapshot);
            SelectedProposal = WorkflowRun.Proposals.FirstOrDefault();
        }
        catch (Exception ex)
        {
            LoadError = ex.Message;
        }

        EnsureAssistantWelcomeMessage();
    }

    private void SelectProposal(HubSpotActionProposal proposal)
    {
        SelectedProposal = proposal;
    }

    private static string PriorityClass(HubSpotProposalPriority priority) => priority switch
    {
        HubSpotProposalPriority.Good => "cockpit-pill-good",
        HubSpotProposalPriority.Unclear => "cockpit-pill-watch",
        HubSpotProposalPriority.Blocked => "hubspot-pill-blocked",
        _ => "cockpit-pill-neutral",
    };

    private static string UseCaseFor(HubSpotActionProposal proposal) => proposal.Kind switch
    {
        HubSpotProposalKind.ReviewOwnerAssignment =>
            "Use this to prevent an orphaned record from becoming a generic or unowned follow-up.",
        HubSpotProposalKind.ReviewLifecycleStage =>
            "Use this to confirm where the account/contact really sits before changing CRM status.",
        HubSpotProposalKind.CleanContactFields =>
            "Use this to clean the minimum handoff context before a seller or marketer acts.",
        HubSpotProposalKind.DraftNextTouchMemo =>
            "Use this as a reviewable follow-up draft, not an automatic HubSpot note.",
        HubSpotProposalKind.ReviewStaleDeal =>
            "Use this to catch stale pipeline timing before forecast or next-step decisions.",
        _ => "Use this to inspect the CRM evidence before deciding the next action.",
    };

    private async Task OnAssistantSendMessageAsync(ChatSendMessageEventArgs args)
    {
        await RunAssistantPromptAsync(args.Message);
    }

    private async Task ApplyAssistantSuggestionAsync(string suggestion)
    {
        await RunAssistantPromptAsync(suggestion);
    }

    private async Task RunAssistantPromptAsync(string? prompt)
    {
        var message = prompt?.Trim();
        if (string.IsNullOrWhiteSpace(message) || IsAssistantResponding)
        {
            return;
        }

        AddAssistantMessage(AssistantUserId, "You", message);

        if (Snapshot is null || WorkflowRun is null)
        {
            AddAssistantMessage(AssistantBotId, "HubSpot AI", "HubSpot workflow run is not loaded yet.");
            return;
        }

        if (!HubSpotAssistant.IsConfigured)
        {
            AddAssistantMessage(AssistantBotId, "HubSpot AI", "Gemini key is not configured for this server. Add it with dotnet user-secrets or an environment variable, then restart the app.");
            return;
        }

        try
        {
            IsAssistantResponding = true;
            await InvokeAsync(StateHasChanged);

            var result = await HubSpotAssistant.AskAsync(message, BuildHubSpotAssistantContext());
            var response = result.Message ?? $"Gemini assistant error: {result.Error ?? "unknown error"}";
            AddAssistantMessage(AssistantBotId, "HubSpot AI", response);
        }
        finally
        {
            IsAssistantResponding = false;
            AssistantChatRef?.Refresh();
        }
    }

    private void ClearAssistantChat()
    {
        AssistantMessages = [];
        EnsureAssistantWelcomeMessage();
        AssistantChatRef?.Refresh();
    }

    private void EnsureAssistantWelcomeMessage()
    {
        if (AssistantMessages.Count > 0)
        {
            return;
        }

        var summary = WorkflowRun is null
            ? "Load HubSpot first, then inspect workflow quality."
            : $"I can analyze the current HubSpot workflow run: {WorkflowRun.Proposals.Count} proposals, {WorkflowRun.Quality.NeedsHumanReview} human-review cases, {WorkflowRun.Quality.BlockedProposals} blocked actions. I will not write to HubSpot from this page.";
        AddAssistantMessage(AssistantBotId, "HubSpot AI", summary);
    }

    private void AddAssistantMessage(string authorId, string authorName, string text)
    {
        AssistantMessages.Add(new AssistantChatMessage
        {
            Id = Guid.NewGuid().ToString("N"),
            AuthorId = authorId,
            AuthorName = authorName,
            Text = text,
            Timestamp = DateTime.Now,
        });
        AssistantChatRef?.Refresh();
    }

    private string BuildHubSpotAssistantContext()
    {
        var builder = new StringBuilder();
        builder.AppendLine($"Today: {DateTime.Today.ToString("yyyy-MM-dd", CultureInfo.InvariantCulture)}");
        builder.AppendLine("Page boundary: read-only HubSpot workflow quality cockpit. The assistant can analyze proposals, draft memos, and explain policy decisions, but no HubSpot write is available on this page.");

        if (Snapshot is null || WorkflowRun is null)
        {
            builder.AppendLine("HubSpot workflow run is not loaded.");
            return builder.ToString();
        }

        builder.AppendLine($"Source: HubSpot API. Portal URL: {Snapshot.PortalUrl}.");
        builder.AppendLine($"Workflow run: {WorkflowRun.Id}. Refreshed: {WorkflowRun.RefreshedAt.ToString("yyyy-MM-dd HH:mm zzz", CultureInfo.InvariantCulture)}.");
        builder.AppendLine($"Quality: {WorkflowRun.Quality.StatusLabel}. Records scanned: {WorkflowRun.Quality.RecordsScanned}. Actionable: {WorkflowRun.Quality.ActionableProposals}. Human review: {WorkflowRun.Quality.NeedsHumanReview}. Blocked: {WorkflowRun.Quality.BlockedProposals}. Unsafe writes: {WorkflowRun.Quality.UnsafeWrites}.");

        builder.AppendLine("Workflow proposals:");
        foreach (var proposal in WorkflowRun.Proposals.Take(12))
        {
            builder.Append("- ");
            builder.Append(proposal.Title);
            builder.Append(" | object ");
            builder.Append(proposal.ObjectType);
            builder.Append(" ");
            builder.Append(proposal.ObjectId);
            builder.Append(" | kind ");
            builder.Append(proposal.Kind);
            builder.Append(" | priority ");
            builder.Append(proposal.Priority);
            builder.Append(" | policy ");
            builder.Append(proposal.Policy.Label);
            AppendContextLine(builder, "evidence", proposal.EvidenceSummary, inline: true);
            AppendContextLine(builder, "proposed action", proposal.ProposedAction, inline: true);
        }

        if (WorkflowRun.Proposals.Count > 12)
        {
            builder.AppendLine($"Additional proposals omitted: {WorkflowRun.Proposals.Count - 12}.");
        }

        return builder.ToString();
    }

    private static void AppendContextLine(StringBuilder builder, string label, string? value, bool inline = false)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return;
        }

        if (inline)
        {
            builder.Append(" | ");
            builder.Append(label);
            builder.Append(": ");
            builder.AppendLine(TrimContextValue(value));
            return;
        }

        builder.Append(label);
        builder.Append(": ");
        builder.AppendLine(TrimContextValue(value));
    }

    private static string TrimContextValue(string value)
    {
        var normalized = string.Join(' ', value.Split((char[]?)null, StringSplitOptions.RemoveEmptyEntries));
        return normalized.Length <= 360
            ? normalized
            : normalized[..360];
    }

    private sealed record ProposalGroup(string Label, IReadOnlyList<HubSpotActionProposal> Proposals);

    private sealed record AssistantSuggestion(string Label, string TestId);

    public sealed class AssistantChatMessage
    {
        public string Id { get; set; } = string.Empty;
        public string AuthorId { get; set; } = string.Empty;
        public string AuthorName { get; set; } = string.Empty;
        public string Text { get; set; } = string.Empty;
        public DateTime Timestamp { get; set; }
    }
}

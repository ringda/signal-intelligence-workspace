@page "/"
@page "/home"
@implements IDisposable
@inject WorkspaceState State
@inject IStringLocalizer<Ui> L

<PageTitle>@L["Nav.Dashboard"] | @L["App.Name"]</PageTitle>

<h2>@L["Dashboard.Title"]</h2>
<p class="muted">@L["Dashboard.Subtitle"]</p>

<TelerikTileLayout Columns="5" RowHeight="150px">
    <TileLayoutItems>
        <TileLayoutItem HeaderText="@L["Kpi.ResourcesReady"]">
            <Content><div class="kpi">@State.ResourcesReady</div></Content>
        </TileLayoutItem>
        <TileLayoutItem HeaderText="@L["Kpi.ItemsNeedingReview"]">
            <Content><div class="kpi">@State.ItemsNeedingReview</div></Content>
        </TileLayoutItem>
        <TileLayoutItem HeaderText="@L["Kpi.MarketSignals"]">
            <Content><div class="kpi">@State.MarketSignalsThisWeek</div></Content>
        </TileLayoutItem>
        <TileLayoutItem HeaderText="@L["Kpi.FeedbackThemes"]">
            <Content><div class="kpi">@State.FeedbackThemeCount</div></Content>
        </TileLayoutItem>
        <TileLayoutItem HeaderText="@L["Kpi.DraftsAwaiting"]">
            <Content><div class="kpi">@State.DraftsAwaitingApproval</div></Content>
        </TileLayoutItem>
    </TileLayoutItems>
</TelerikTileLayout>

@code {
    protected override void OnInitialized() => State.Changed += OnStateChanged;

    private void OnStateChanged() => InvokeAsync(StateHasChanged);

    public void Dispose() => State.Changed -= OnStateChanged;
}

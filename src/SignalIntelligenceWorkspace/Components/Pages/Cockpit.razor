@page "/"
@page "/home"
@page "/cockpit"
@implements IDisposable
@inject CockpitDataService CockpitData
@inject CockpitSemanticGridAiParser SemanticGridAiParser
@inject IStringLocalizer<Ui> L
@inject PersistentComponentState ApplicationState
@using System.Globalization
@using System.Text

<PageTitle>@L["Nav.Cockpit"] | @L["App.Name"]</PageTitle>

<div class="cockpit-page">
    <div class="cockpit-header">
        <div>
            <h2>@L["Cockpit.Title"]</h2>
            <p class="muted">@L["Cockpit.Subtitle"]</p>
        </div>
        @if (Metrics is not null)
        {
            <div class="cockpit-source-card">
                <span>Source</span>
                <strong>Direct Postgres</strong>
                <span>@RecentJobs.Count recent jobs loaded</span>
                <span>Refreshed @SnapshotLoadedAt.ToString("MMM d, yyyy h:mm tt", CultureInfo.InvariantCulture)</span>
            </div>
        }
    </div>

    @if (!string.IsNullOrWhiteSpace(LoadError))
    {
        <div class="cockpit-alert">@LoadError</div>
    }
    else if (IsLoading)
    {
        <div class="cockpit-loading">@L["Cockpit.Loading"]</div>
    }
    else
    {
        <div class="cockpit-action-row">
            <span class="cockpit-policy">Read-only direct DB page. No write executed.</span>
            @if (Metrics is not null)
            {
                <span class="cockpit-policy">@Metrics.LocalToday.ToString("yyyy-MM-dd", CultureInfo.InvariantCulture) · @Metrics.MetricTimezone</span>
            }
        </div>

        <section class="cockpit-truth-panel">
            <strong>What is real here</strong>
            <span>
                The Application Tracker now reads directly from the job-search database tables:
                core.jobs, core.applications, and core.descriptions. The assistant can reason over
                the loaded snapshot, but this page does not update the database.
            </span>
        </section>

        @if (Metrics is not null)
        {
            <section class="cockpit-summary-grid" aria-label="@L["Cockpit.Kpis"]">
                @SummaryTile(L["Cockpit.Kpi.ApplicationsToday"], Metrics.ApplicationsAppliedToday, Metrics.ApplicationsAppliedTarget, true)
                @SummaryTile(L["Cockpit.Kpi.ApplicationsWeek"], Metrics.ApplicationsAppliedWeek, Metrics.ApplicationsAppliedWeekTarget, true)
                @SummaryTile(L["Cockpit.Kpi.Jd24h"], Metrics.JdScanned24h, Metrics.JdScannedTarget, false)
                @SummaryTile(L["Cockpit.Kpi.CorrectPool"], Metrics.JdCorrectPool24h, Math.Max(Metrics.JdScannedTarget, 1), false)
            </section>
        }

        <section class="cockpit-band" aria-label="@L["Cockpit.Pipeline"]">
            <div class="cockpit-section-head">
                <h3>@L["Cockpit.Pipeline"]</h3>
            </div>
            <div class="cockpit-timeline">
                @foreach (var step in PipelineSteps)
                {
                    <div class="cockpit-step @StepClass(step)">
                        <div class="cockpit-step-marker">@step.StepOrder</div>
                        <div class="cockpit-step-body">
                            <span class="cockpit-step-label">@StepLabel(step)</span>
                            <span class="cockpit-step-count">@step.ActualCount / @step.TargetCount</span>
                        </div>
                    </div>
                }
            </div>
        </section>

        <section class="cockpit-main">
            <div class="cockpit-chart-panel">
                <div class="cockpit-section-head">
                    <h3>@L["Cockpit.ChartTitle"]</h3>
                </div>
                <TelerikChart Height="300px">
                    <ChartSeriesItems>
                        <ChartSeries Type="@ChartSeriesType.Line"
                                     Name="@(L["Cockpit.Chart.Applied"])"
                                     Data="@DailySeries"
                                     Field="@nameof(CockpitDailySeries.ApplicationsApplied)"
                                     CategoryField="@nameof(CockpitDailySeries.Day)" />
                        <ChartSeries Type="@ChartSeriesType.Line"
                                     Name="@(L["Cockpit.Chart.Target"])"
                                     Data="@DailySeries"
                                     Field="@nameof(CockpitDailySeries.ApplicationsAppliedTarget)"
                                     CategoryField="@nameof(CockpitDailySeries.Day)" />
                        <ChartSeries Type="@ChartSeriesType.Line"
                                     Name="@(L["Cockpit.Chart.Jds"])"
                                     Data="@DailySeries"
                                     Field="@nameof(CockpitDailySeries.JdScanned)"
                                     CategoryField="@nameof(CockpitDailySeries.Day)" />
                    </ChartSeriesItems>
                    <ChartCategoryAxes>
                        <ChartCategoryAxis Type="@ChartCategoryAxisType.Date"
                                           BaseUnit="@ChartCategoryAxisBaseUnit.Days" />
                    </ChartCategoryAxes>
                    <ChartValueAxes>
                        <ChartValueAxis Min="0" MajorUnit="1" />
                    </ChartValueAxes>
                </TelerikChart>
            </div>

            <div class="cockpit-grid-panel">
                <div class="cockpit-grid-toolbar">
                    <div class="cockpit-section-head">
                        <h3>@L["Cockpit.RecentJobs"]</h3>
                        <span class="cockpit-grid-count">@L["Cockpit.Semantic.Count", VisibleRecentJobs.Count, RecentJobs.Count]</span>
                    </div>
                    <div class="cockpit-semantic-row" aria-label="@L["Cockpit.Semantic.Label"]">
                        <label class="sr-only" for="cockpit-semantic-grid">@L["Cockpit.Semantic.Label"]</label>
                        <input id="cockpit-semantic-grid"
                               class="cockpit-semantic-input"
                               @bind="SemanticGridPrompt"
                               @bind:event="oninput"
                               @onkeydown="OnSemanticGridKeyDown"
                               disabled="@IsSemanticGridApplying"
                               placeholder="@L["Cockpit.Semantic.Placeholder"]" />
                        <TelerikButton OnClick="@ApplySemanticGridCommandAsync"
                                       Enabled="@(!IsSemanticGridApplying)">@L["Cockpit.Semantic.Apply"]</TelerikButton>
                        <TelerikButton OnClick="@(() => ClearSemanticGridCommand())"
                                       Enabled="@(HasSemanticGridControl && !IsSemanticGridApplying)"
                                       FillMode="@ThemeConstants.Button.FillMode.Flat">@L["Action.Clear"]</TelerikButton>
                    </div>
                    <div class="cockpit-semantic-suggestions">
                        @foreach (var suggestion in SemanticGridSuggestions)
                        {
                            <button type="button"
                                    class="cockpit-semantic-chip"
                                    @onclick="@(() => ApplySemanticGridSuggestionAsync(suggestion))">
                                @suggestion
                            </button>
                        }
                    </div>
                    @if (!string.IsNullOrWhiteSpace(SemanticGridMessage))
                    {
                        <div class="cockpit-semantic-status @SemanticGridMessageClass">@SemanticGridMessage</div>
                    }
                </div>
                <TelerikGrid Data="@VisibleRecentJobs"
                             Height="420px"
                             Sortable="true"
                             FilterMode="@GridFilterMode.FilterMenu"
                             SelectionMode="@GridSelectionMode.Single"
                             SelectedItems="@SelectedJobs"
                             OnRowClick="@OnRecentJobRowClick">
                    <GridColumns>
                        <GridColumn Field="@nameof(CockpitRecentJob.Company)" Title="@(L["Cockpit.Col.Company"])" Width="170px" />
                        <GridColumn Field="@nameof(CockpitRecentJob.Title)" Title="@(L["Cockpit.Col.Title"])" Width="280px" />
                        <GridColumn Field="@nameof(CockpitRecentJob.StatusCode)" Title="@(L["Cockpit.Col.Status"])" Width="140px">
                            <Template>
                                @{
                                    var job = (CockpitRecentJob)context;
                                }
                                <span class="cockpit-pill @StatusClass(job.StatusCode)">@StatusDisplay(job.StatusCode)</span>
                            </Template>
                        </GridColumn>
                        <GridColumn Field="@nameof(CockpitRecentJob.MatchLevel)" Title="@(L["Cockpit.Col.Match"])" Width="150px">
                            <Template>
                                @{
                                    var job = (CockpitRecentJob)context;
                                }
                                @MatchDisplay(job.MatchLevel)
                            </Template>
                        </GridColumn>
                        <GridColumn Field="@nameof(CockpitRecentJob.JudgementSummary)" Title="@(L["Cockpit.Col.Judgement"])" Width="420px" />
                    </GridColumns>
                </TelerikGrid>
            </div>

            <aside class="cockpit-detail-panel">
                <div class="cockpit-section-head">
                    <h3>@L["Cockpit.Evidence"]</h3>
                </div>
                @if (IsDetailLoading)
                {
                    <div class="cockpit-loading">@L["Cockpit.Loading"]</div>
                }
                else if (SelectedJobProcess is null)
                {
                    <div class="cockpit-empty">@L["Cockpit.Evidence.Empty"]</div>
                }
                else
                {
                    <div class="cockpit-detail-title">
                        <strong>@SelectedJobProcess.Company</strong>
                        <span>@SelectedJobProcess.Title</span>
                    </div>
                    <div class="cockpit-detail-meta">
                        <span class="cockpit-pill @StatusClass(SelectedJobProcess.StatusCode)">@StatusDisplay(SelectedJobProcess.StatusCode)</span>
                        @if (!string.IsNullOrWhiteSpace(SelectedJobProcess.MatchLevel))
                        {
                            <span>@MatchDisplay(SelectedJobProcess.MatchLevel)</span>
                        }
                        @if (SelectedJobProcess.WinScore is not null)
                        {
                            <span>@L["Cockpit.WinScore"] @SelectedJobProcess.WinScore</span>
                        }
                    </div>

                    @EvidenceBlock(L["Cockpit.Evidence.RoleSummary"], SelectedJobProcess.PjdRoleSummary)
                    @EvidenceBlock(L["Cockpit.Evidence.HiringFocus"], SelectedJobProcess.PjdHiringFocus)
                    @EvidenceBlock(L["Cockpit.Evidence.WinReasoning"], SelectedJobProcess.WinReasoning)
                    @EvidenceBlock(L["Cockpit.Evidence.Disposition"], SelectedJobProcess.DispositionNote)
                    @EvidenceBlock(L["Cockpit.Evidence.Visa"], SelectedJobProcess.VisaNote)

                    @if (!string.IsNullOrWhiteSpace(SelectedJobProcess.PipelineFolder))
                    {
                        <div class="cockpit-path">
                            <span>@L["Cockpit.Evidence.Folder"]</span>
                            <code>80-applications/@SelectedJobProcess.PipelineFolder</code>
                        </div>
                    }
                }
            </aside>

            <aside class="cockpit-assistant-panel" aria-label="@L["Cockpit.Assistant"]">
                <div class="cockpit-assistant-header">
                    <div class="cockpit-assistant-title">
                        <TelerikSvgIcon Icon="@SvgIcon.Sparkles" />
                        <h3>@L["Cockpit.Assistant"]</h3>
                    </div>
                    <TelerikButton OnClick="@ClearAssistantChat"
                                   FillMode="@ThemeConstants.Button.FillMode.Flat"
                                   Enabled="@(!IsAssistantResponding)">
                        @L["Action.Clear"]
                    </TelerikButton>
                </div>
                <div class="cockpit-assistant-context">@AssistantContextSummary</div>
                <div class="cockpit-assistant-suggestions">
                    @foreach (var suggestion in AssistantSuggestions)
                    {
                        <button type="button"
                                class="cockpit-assistant-chip"
                                disabled="@IsAssistantResponding"
                                @onclick="@(() => ApplyAssistantSuggestionAsync(suggestion))">
                            @suggestion
                        </button>
                    }
                </div>
                @if (!SemanticGridAiParser.IsConfigured)
                {
                    <div class="cockpit-assistant-status cockpit-assistant-status-error">
                        @L["Cockpit.Assistant.NotConfigured"]
                    </div>
                }
                else if (IsAssistantResponding)
                {
                    <div class="cockpit-assistant-status">
                        @L["Cockpit.Assistant.Thinking", SemanticGridAiParser.ProviderName]
                    </div>
                }
                <div class="cockpit-assistant-chat">
                    <TelerikChat TItem="AssistantChatMessage"
                                 @ref="@AssistantChatRef"
                                 Data="@AssistantMessages"
                                 AuthorId="@AssistantUserId"
                                 EnableSpeechToText="true"
                                 OnSendMessage="@OnAssistantSendMessageAsync"
                                 Height="520px"
                                 Width="100%">
                    </TelerikChat>
                </div>
            </aside>
        </section>

        <section class="cockpit-band cockpit-readiness-panel">
            <div class="cockpit-section-head">
                <div>
                    <h3>Application Readiness</h3>
                    <p class="muted">Recent jobs translated into fit signal, evidence state, and next action.</p>
                </div>
            </div>

            @if (ApplicationReadinessJobs.Count == 0)
            {
                <div class="cockpit-empty">No recent application readiness cards are available.</div>
            }
            else
            {
                <div class="application-readiness-grid">
                    @foreach (var job in ApplicationReadinessJobs)
                    {
                        <article class="application-readiness-card">
                            <div class="application-card-head">
                                <div>
                                    <strong>@job.Company</strong>
                                    <span>@job.Title</span>
                                </div>
                                <span class="cockpit-pill @StatusClass(job.StatusCode)">@StatusDisplay(job.StatusCode)</span>
                            </div>

                            <div class="application-card-meta">
                                <span>@(string.IsNullOrWhiteSpace(job.Location) ? "No location" : job.Location)</span>
                                <span>@MatchDisplay(job.MatchLevel)</span>
                                <span>@job.CreatedAt.ToString("MMM d, yyyy", CultureInfo.InvariantCulture)</span>
                                <span>@(string.IsNullOrWhiteSpace(job.PipelineFolder) ? "Not initialized" : $"80-applications/{job.PipelineFolder}")</span>
                            </div>

                            <div class="application-score">
                                <span>@ApplicationReadinessScore(job) / 100</span>
                                <div class="application-score-track">
                                    <div style="@($"width: {ApplicationReadinessScore(job)}%")"></div>
                                </div>
                            </div>

                            <div class="application-card-block">
                                <small>Next action</small>
                                <span>@ApplicationNextAction(job)</span>
                            </div>

                            <div class="application-card-block">
                                <small>Evidence</small>
                                <span>@(string.IsNullOrWhiteSpace(job.JudgementSummary) ? "No judgement summary loaded." : job.JudgementSummary)</span>
                            </div>
                        </article>
                    }
                </div>
            }
        </section>

        <div class="cockpit-meta">@L["Cockpit.Meta"]</div>
    }
</div>

@code {
    private const string SnapshotKey = "cockpit-summary-v1";
    private PersistingComponentStateSubscription? _persistingSubscription;

    private bool IsLoading = true;
    private bool IsDetailLoading;
    private string? LoadError;
    private DateTimeOffset SnapshotLoadedAt = DateTimeOffset.Now;

    private CockpitDailyMetrics? Metrics;
    private List<CockpitDailySeries> DailySeries = [];
    private List<CockpitPipelineStep> PipelineSteps = [];
    private List<CockpitRecentJob> RecentJobs = [];
    private string SemanticGridPrompt = string.Empty;
    private string? SemanticGridMessage;
    private bool IsSemanticGridApplying;
    private bool SemanticGridNoMatch;
    private SemanticGridFilter ActiveSemanticGridFilter = SemanticGridFilter.All;
    private SemanticGridDateWindow ActiveSemanticGridDateWindow = SemanticGridDateWindow.None;
    private SemanticGridSort ActiveSemanticGridSort = SemanticGridSort.None;
    private string? ActiveSemanticGridCompany;
    private string? ActiveSemanticGridContentQuery;
    private IReadOnlyList<string> ActiveSemanticGridContentTerms = [];
    private IEnumerable<CockpitRecentJob> SelectedJobs = [];
    private CockpitJobProcess? SelectedJobProcess;
    private TelerikChat<AssistantChatMessage>? AssistantChatRef { get; set; }
    private List<AssistantChatMessage> AssistantMessages = [];
    private bool IsAssistantResponding;

    private const string AssistantUserId = "cockpit-user";
    private const string AssistantBotId = "cockpit-assistant";

    private IReadOnlyList<string> SemanticGridSuggestions =>
    [
        L["Cockpit.Semantic.Suggestion.Strong"].Value,
        L["Cockpit.Semantic.Suggestion.Possible"].Value,
        L["Cockpit.Semantic.Suggestion.Review"].Value,
        L["Cockpit.Semantic.Suggestion.Sales"].Value,
        L["Cockpit.Semantic.Suggestion.RecentApplied"].Value,
        L["Cockpit.Semantic.Suggestion.Company"].Value,
    ];

    private IReadOnlyList<string> AssistantSuggestions =>
    [
        L["Cockpit.Assistant.Suggestion.SelectedSummary"].Value,
        L["Cockpit.Assistant.Suggestion.NextAction"].Value,
        L["Cockpit.Assistant.Suggestion.Risks"].Value,
        L["Cockpit.Assistant.Suggestion.Compare"].Value,
    ];

    private IReadOnlyList<CockpitRecentJob> VisibleRecentJobs
    {
        get
        {
            IEnumerable<CockpitRecentJob> jobs = ActiveSemanticGridFilter switch
            {
                SemanticGridFilter.StrongFit => RecentJobs.Where(IsStrongFit),
                SemanticGridFilter.PossibleFit => RecentJobs.Where(IsPossibleFit),
                SemanticGridFilter.NeedsReview => RecentJobs.Where(IsNeedsReview),
                SemanticGridFilter.Applied => RecentJobs.Where(job => IsStatus(job, "applied")),
                _ => RecentJobs,
            };

            if (!string.IsNullOrWhiteSpace(ActiveSemanticGridCompany))
            {
                jobs = jobs.Where(job =>
                    string.Equals(job.Company, ActiveSemanticGridCompany, StringComparison.OrdinalIgnoreCase));
            }

            if (HasSemanticGridContent)
            {
                jobs = jobs.Where(MatchesSemanticContent);
            }

            jobs = ActiveSemanticGridDateWindow switch
            {
                SemanticGridDateWindow.LastThreeDays => jobs.Where(IsInLastThreeCalendarDays),
                _ => jobs,
            };

            jobs = ActiveSemanticGridSort switch
            {
                SemanticGridSort.Company => jobs.OrderBy(job => job.Company).ThenByDescending(job => job.CreatedAt),
                SemanticGridSort.FitScore => jobs.OrderByDescending(SemanticScore).ThenBy(job => job.Company),
                SemanticGridSort.Newest => jobs.OrderByDescending(job => job.CreatedAt),
                _ => jobs,
            };

            return jobs.ToList();
        }
    }

    private bool HasSemanticGridControl =>
        ActiveSemanticGridFilter is not SemanticGridFilter.All ||
        ActiveSemanticGridDateWindow is not SemanticGridDateWindow.None ||
        ActiveSemanticGridSort is not SemanticGridSort.None ||
        !string.IsNullOrWhiteSpace(ActiveSemanticGridCompany) ||
        HasSemanticGridContent;

    private bool HasSemanticGridContent =>
        !string.IsNullOrWhiteSpace(ActiveSemanticGridContentQuery) ||
        ActiveSemanticGridContentTerms.Count > 0;

    private IReadOnlyList<CockpitRecentJob> ApplicationReadinessJobs =>
        RecentJobs
            .OrderByDescending(ApplicationReadinessSortScore)
            .ThenByDescending(job => job.CreatedAt)
            .Take(8)
            .ToList();

    private string SemanticGridMessageClass =>
        SemanticGridNoMatch ? "cockpit-semantic-status-error" : string.Empty;

    private string AssistantContextSummary =>
        L["Cockpit.Assistant.Context", SemanticGridSummary, VisibleRecentJobs.Count, RecentJobs.Count].Value;

    protected override async Task OnInitializedAsync()
    {
        _persistingSubscription = ApplicationState.RegisterOnPersisting(PersistSnapshot);
        EnsureAssistantWelcomeMessage();

        if (ApplicationState.TryTakeFromJson<CockpitSnapshot>(SnapshotKey, out var snapshot) && snapshot is not null)
        {
            Metrics = snapshot.Metrics;
            DailySeries = snapshot.DailySeries;
            PipelineSteps = snapshot.PipelineSteps;
            RecentJobs = snapshot.RecentJobs;
            SnapshotLoadedAt = DateTimeOffset.Now;
            IsLoading = false;
            return;
        }

        await LoadSummaryAsync();
    }

    private void EnsureAssistantWelcomeMessage()
    {
        if (AssistantMessages.Count > 0)
        {
            return;
        }

        AddAssistantMessage(AssistantBotId, L["Cockpit.Assistant.Name"].Value, L["Cockpit.Assistant.Welcome"].Value);
    }

    private async Task LoadSummaryAsync()
    {
        try
        {
            IsLoading = true;
            LoadError = null;

            Metrics = await CockpitData.GetDailyMetricsAsync();
            DailySeries = await CockpitData.GetDailySeriesAsync();
            PipelineSteps = await CockpitData.GetTodayPipelineStepsAsync();
            RecentJobs = await CockpitData.GetRecentJobsAsync();
            SnapshotLoadedAt = DateTimeOffset.Now;
        }
        catch (Exception ex)
        {
            LoadError = ex.Message;
        }
        finally
        {
            IsLoading = false;
        }
    }

    private async Task OnRecentJobRowClick(GridRowClickEventArgs args)
    {
        if (args.Item is CockpitRecentJob selected)
        {
            await LoadJobProcessAsync(selected);
        }
    }

    private async Task LoadJobProcessAsync(CockpitRecentJob selected)
    {
        SelectedJobs = [selected];
        SelectedJobProcess = null;

        try
        {
            IsDetailLoading = true;
            SelectedJobProcess = await CockpitData.GetJobProcessAsync(selected.JobId);
        }
        finally
        {
            IsDetailLoading = false;
        }
    }

    private Task PersistSnapshot()
    {
        ApplicationState.PersistAsJson(SnapshotKey, new CockpitSnapshot
        {
            Metrics = Metrics,
            DailySeries = DailySeries,
            PipelineSteps = PipelineSteps,
            RecentJobs = RecentJobs,
        });
        return Task.CompletedTask;
    }

    private async Task ApplySemanticGridSuggestionAsync(string suggestion)
    {
        SemanticGridPrompt = suggestion;
        await ApplySemanticGridCommandAsync();
    }

    private async Task ApplySemanticGridCommandAsync()
    {
        var command = SemanticGridPrompt.Trim();
        if (string.IsNullOrWhiteSpace(command))
        {
            SemanticGridNoMatch = true;
            SemanticGridMessage = L["Cockpit.Semantic.Empty"];
            return;
        }

        IsSemanticGridApplying = true;
        SemanticGridNoMatch = false;
        SemanticGridMessage = SemanticGridAiParser.IsConfigured
            ? L["Cockpit.Semantic.ParsingAi", SemanticGridAiParser.ProviderName].Value
            : null;

        try
        {
            var parseAttempt = await ParseSemanticGridCommandAsync(command);
            ApplySemanticGridParseResult(parseAttempt);
        }
        finally
        {
            IsSemanticGridApplying = false;
        }
    }

    private void ApplySemanticGridParseResult(SemanticGridParseAttempt parseAttempt)
    {
        var result = parseAttempt.Result;
        if (result.Clear)
        {
            ClearSemanticGridCommand(L["Cockpit.Semantic.Cleared"]);
            return;
        }

        if (!result.Matched)
        {
            SemanticGridNoMatch = true;
            SemanticGridMessage = parseAttempt.Source is SemanticGridParseSource.Ai &&
                                  !string.IsNullOrWhiteSpace(parseAttempt.AiReason)
                ? L["Cockpit.Semantic.NoMatchAi", parseAttempt.ProviderName, parseAttempt.AiReason ?? string.Empty].Value
                : L["Cockpit.Semantic.NoMatch"];
            return;
        }

        if (result.Filter is not null)
        {
            ActiveSemanticGridFilter = result.Filter.Value;
        }

        if (result.DateWindow is not null)
        {
            ActiveSemanticGridDateWindow = result.DateWindow.Value;
        }

        if (result.Sort is not null)
        {
            ActiveSemanticGridSort = result.Sort.Value;
        }

        if (result.Company is not null)
        {
            ActiveSemanticGridCompany = result.Company;
        }

        if (result.ContentQuery is not null || result.ContentTerms.Count > 0)
        {
            ActiveSemanticGridContentQuery = result.ContentQuery;
            ActiveSemanticGridContentTerms = result.ContentTerms;
        }

        SemanticGridNoMatch = false;
        SemanticGridMessage = parseAttempt.Source switch
        {
            SemanticGridParseSource.Ai => L["Cockpit.Semantic.AppliedAi", parseAttempt.ProviderName, SemanticGridSummary, VisibleRecentJobs.Count].Value,
            SemanticGridParseSource.LocalRules when !string.IsNullOrWhiteSpace(parseAttempt.AiWarning) =>
                L["Cockpit.Semantic.AiFailedRules", parseAttempt.ProviderName, parseAttempt.AiWarning ?? string.Empty, SemanticGridSummary, VisibleRecentJobs.Count].Value,
            _ => L["Cockpit.Semantic.Applied", SemanticGridSummary, VisibleRecentJobs.Count].Value,
        };
        EnsureSelectedJobIsVisible();
    }

    private void ClearSemanticGridCommand() => ClearSemanticGridCommand(null);

    private void ClearSemanticGridCommand(string? message)
    {
        SemanticGridPrompt = string.Empty;
        ActiveSemanticGridFilter = SemanticGridFilter.All;
        ActiveSemanticGridDateWindow = SemanticGridDateWindow.None;
        ActiveSemanticGridSort = SemanticGridSort.None;
        ActiveSemanticGridCompany = null;
        ActiveSemanticGridContentQuery = null;
        ActiveSemanticGridContentTerms = [];
        SemanticGridNoMatch = false;
        SemanticGridMessage = message;
        EnsureSelectedJobIsVisible();
    }

    private async Task OnSemanticGridKeyDown(KeyboardEventArgs args)
    {
        if (args.Key is "Enter")
        {
            await ApplySemanticGridCommandAsync();
        }
    }

    private async Task OnAssistantSendMessageAsync(ChatSendMessageEventArgs args)
    {
        await RunAssistantPromptAsync(args.Message);
    }

    private async Task ApplyAssistantSuggestionAsync(string suggestion)
    {
        await RunAssistantPromptAsync(suggestion);
    }

    private async Task RunAssistantPromptAsync(string? prompt)
    {
        var message = prompt?.Trim();
        if (string.IsNullOrWhiteSpace(message) || IsAssistantResponding)
        {
            return;
        }

        AddAssistantMessage(AssistantUserId, L["Cockpit.Assistant.User"].Value, message);

        if (!SemanticGridAiParser.IsConfigured)
        {
            AddAssistantMessage(AssistantBotId, L["Cockpit.Assistant.Name"].Value, L["Cockpit.Assistant.NotConfigured"].Value);
            return;
        }

        try
        {
            IsAssistantResponding = true;
            await InvokeAsync(StateHasChanged);

            var result = await SemanticGridAiParser.AskAssistantAsync(message, BuildAssistantContext());
            var response = result.Message ??
                           L["Cockpit.Assistant.Error", result.Error ?? L["Cockpit.Semantic.AiUnknownError"].Value].Value;
            AddAssistantMessage(AssistantBotId, L["Cockpit.Assistant.Name"].Value, response);
        }
        finally
        {
            IsAssistantResponding = false;
            AssistantChatRef?.Refresh();
        }
    }

    private void ClearAssistantChat()
    {
        AssistantMessages = [];
        EnsureAssistantWelcomeMessage();
        AssistantChatRef?.Refresh();
    }

    private void AddAssistantMessage(string authorId, string authorName, string text)
    {
        AssistantMessages.Add(new AssistantChatMessage
        {
            Id = Guid.NewGuid().ToString("N"),
            AuthorId = authorId,
            AuthorName = authorName,
            Text = text,
            Timestamp = DateTime.Now,
        });
        AssistantChatRef?.Refresh();
    }

    private string BuildAssistantContext()
    {
        var visibleJobs = VisibleRecentJobs;
        var selectedJob = SelectedJobs.FirstOrDefault();
        var builder = new StringBuilder();

        builder.AppendLine($"Today: {(Metrics?.LocalToday.ToString("yyyy-MM-dd", CultureInfo.InvariantCulture) ?? DateTime.Today.ToString("yyyy-MM-dd", CultureInfo.InvariantCulture))}");
        builder.AppendLine($"Current grid scope: {SemanticGridSummary}; visible jobs: {visibleJobs.Count} of {RecentJobs.Count}.");

        if (Metrics is not null)
        {
            builder.AppendLine($"Daily metrics: applications today {Metrics.ApplicationsAppliedToday}/{Metrics.ApplicationsAppliedTarget}; applications this week {Metrics.ApplicationsAppliedWeek}/{Metrics.ApplicationsAppliedWeekTarget}; JDs scanned 24h {Metrics.JdScanned24h}/{Metrics.JdScannedTarget}; correct-pool 24h {Metrics.JdCorrectPool24h}.");
        }

        if (selectedJob is not null)
        {
            builder.AppendLine("Selected grid row:");
            AppendRecentJobContext(builder, selectedJob);
        }

        if (SelectedJobProcess is not null)
        {
            builder.AppendLine("Selected application notes:");
            AppendContextLine(builder, "Company", SelectedJobProcess.Company);
            AppendContextLine(builder, "Title", SelectedJobProcess.Title);
            AppendContextLine(builder, "Status", StatusDisplay(SelectedJobProcess.StatusCode));
            AppendContextLine(builder, "Match", MatchDisplay(SelectedJobProcess.MatchLevel));
            AppendContextLine(builder, "Win score", SelectedJobProcess.WinScore?.ToString(CultureInfo.InvariantCulture));
            AppendContextLine(builder, "Role summary", SelectedJobProcess.PjdRoleSummary);
            AppendContextLine(builder, "Hiring focus", SelectedJobProcess.PjdHiringFocus);
            AppendContextLine(builder, "Fit notes", SelectedJobProcess.WinReasoning);
            AppendContextLine(builder, "Next step", SelectedJobProcess.DispositionNote);
            AppendContextLine(builder, "Work authorization", SelectedJobProcess.VisaNote);
        }

        builder.AppendLine("Visible jobs:");
        foreach (var job in visibleJobs.Take(8))
        {
            AppendRecentJobContext(builder, job);
        }

        if (visibleJobs.Count > 8)
        {
            builder.AppendLine($"Additional visible jobs omitted: {visibleJobs.Count - 8}.");
        }

        return builder.ToString();
    }

    private void AppendRecentJobContext(StringBuilder builder, CockpitRecentJob job)
    {
        builder.Append("- ");
        builder.Append(job.Company);
        builder.Append(" | ");
        builder.Append(job.Title);
        builder.Append(" | status ");
        builder.Append(StatusDisplay(job.StatusCode));
        builder.Append(" | match ");
        builder.Append(MatchDisplay(job.MatchLevel));

        if (job.WinScore is not null || job.MatchScore is not null)
        {
            builder.Append(" | score ");
            builder.Append((job.WinScore ?? job.MatchScore)?.ToString(CultureInfo.InvariantCulture));
        }

        builder.Append(" | created ");
        builder.Append(job.CreatedAt.ToString("yyyy-MM-dd", CultureInfo.InvariantCulture));
        AppendContextLine(builder, "notes", job.JudgementSummary, inline: true);
    }

    private static void AppendContextLine(StringBuilder builder, string label, string? value, bool inline = false)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return;
        }

        if (inline)
        {
            builder.Append(" | ");
            builder.Append(label);
            builder.Append(": ");
            builder.AppendLine(TrimContextValue(value));
            return;
        }

        builder.Append(label);
        builder.Append(": ");
        builder.AppendLine(TrimContextValue(value));
    }

    private static string TrimContextValue(string value)
    {
        var normalized = string.Join(' ', value.Split((char[]?)null, StringSplitOptions.RemoveEmptyEntries));
        return normalized.Length <= 360
            ? normalized
            : normalized[..360];
    }

    private async Task<SemanticGridParseAttempt> ParseSemanticGridCommandAsync(string command)
    {
        if (!SemanticGridAiParser.IsConfigured)
        {
            return SemanticGridParseAttempt.Local(ParseSemanticGridCommand(command));
        }

        var aiResult = await SemanticGridAiParser.ParseAsync(command);
        if (aiResult.Command is not null)
        {
            return SemanticGridParseAttempt.Ai(
                ConvertAiSemanticGridCommand(aiResult.Command, command),
                aiResult.Command.Reason,
                SemanticGridAiParser.ProviderName);
        }

        return SemanticGridParseAttempt.Local(
            ParseSemanticGridCommand(command),
            aiResult.Error ?? L["Cockpit.Semantic.AiUnknownError"].Value,
            SemanticGridAiParser.ProviderName);
    }

    private SemanticGridParseResult ConvertAiSemanticGridCommand(
        CockpitSemanticGridAiCommand command,
        string rawCommand)
    {
        if (command.Clear)
        {
            return SemanticGridParseResult.ForClear();
        }

        if (!command.Matched)
        {
            return SemanticGridParseResult.NoMatch();
        }

        var filter = command.Filter switch
        {
            "strongFit" => SemanticGridFilter.StrongFit,
            "possibleFit" => SemanticGridFilter.PossibleFit,
            "needsReview" => SemanticGridFilter.NeedsReview,
            "applied" => SemanticGridFilter.Applied,
            _ => (SemanticGridFilter?)null,
        };

        var dateWindow = command.DateWindow switch
        {
            "lastThreeDays" => SemanticGridDateWindow.LastThreeDays,
            _ => (SemanticGridDateWindow?)null,
        };

        var sort = command.Sort switch
        {
            "newest" => SemanticGridSort.Newest,
            "company" => SemanticGridSort.Company,
            "fitScore" => SemanticGridSort.FitScore,
            _ => (SemanticGridSort?)null,
        };

        var company = FindCompanyFilter(rawCommand, NormalizeCommand(rawCommand));
        var contentQuery = SanitizeSemanticContentQuery(command.ContentQuery);
        var contentTerms = BuildSemanticContentTerms(contentQuery, command.ContentTerms);

        return filter is null &&
               dateWindow is null &&
               sort is null &&
               company is null &&
               contentQuery is null &&
               contentTerms.Count == 0
            ? SemanticGridParseResult.NoMatch()
            : SemanticGridParseResult.Match(filter, dateWindow, sort, company, contentQuery, contentTerms);
    }

    private void EnsureSelectedJobIsVisible()
    {
        var selected = SelectedJobs.FirstOrDefault();
        if (selected is null || VisibleRecentJobs.Any(job => job.JobId == selected.JobId))
        {
            return;
        }

        SelectedJobs = [];
        SelectedJobProcess = null;
    }

    private SemanticGridParseResult ParseSemanticGridCommand(string command)
    {
        var normalized = NormalizeCommand(command);
        if (ContainsAny(normalized, "clear", "reset", "showall", "全部", "清除", "重置", "還原"))
        {
            return SemanticGridParseResult.ForClear();
        }

        SemanticGridFilter? filter = null;
        SemanticGridDateWindow? dateWindow = null;
        SemanticGridSort? sort = null;
        var company = FindCompanyFilter(command, normalized);
        var contentQuery = TryCreateLocalContentQuery(command, normalized);

        if (ContainsAny(normalized, "高度適合", "優先", "strong", "best", "recommended"))
        {
            filter = SemanticGridFilter.StrongFit;
        }
        else if (ContainsAny(normalized, "可以考慮", "可考慮", "possible", "medium", "edge"))
        {
            filter = SemanticGridFilter.PossibleFit;
        }
        else if (ContainsAny(normalized, "待評估", "授權", "暫緩", "review", "visa", "pending", "hold", "unclear"))
        {
            filter = SemanticGridFilter.NeedsReview;
        }
        else if (ContainsAny(normalized, "已申請", "已送出", "送出申請", "已投", "投遞", "applied", "sent"))
        {
            filter = SemanticGridFilter.Applied;
        }

        if (ContainsAny(
                normalized,
                "最近三天",
                "近三天",
                "最近3天",
                "近3天",
                "三天內",
                "3天內",
                "最近三日",
                "近三日",
                "last3days",
                "past3days",
                "lastthreedays",
                "pastthreedays"))
        {
            dateWindow = SemanticGridDateWindow.LastThreeDays;
        }

        if (ContainsAny(normalized, "依公司", "公司排序", "sortbycompany") ||
            (ContainsAny(normalized, "公司", "company") && ContainsAny(normalized, "排序", "sort", "order")))
        {
            sort = SemanticGridSort.Company;
        }
        else if (ContainsAny(normalized, "最新", "時間", "recent", "newest", "date"))
        {
            sort = SemanticGridSort.Newest;
        }
        else if (ContainsAny(normalized, "分數", "score") ||
                 (ContainsAny(normalized, "排序", "sort") && ContainsAny(normalized, "適合", "fit")))
        {
            sort = SemanticGridSort.FitScore;
        }

        if (dateWindow is not null && sort is null)
        {
            sort = SemanticGridSort.Newest;
        }

        return filter is null &&
               dateWindow is null &&
               sort is null &&
               company is null &&
               contentQuery is null
            ? SemanticGridParseResult.NoMatch()
            : SemanticGridParseResult.Match(
                filter,
                dateWindow,
                sort,
                company,
                contentQuery?.Query,
                contentQuery?.Terms ?? []);
    }


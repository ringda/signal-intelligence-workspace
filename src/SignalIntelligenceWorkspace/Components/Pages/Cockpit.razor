    private string StepLabel(CockpitPipelineStep step) =>
        CultureInfo.CurrentUICulture.Name.StartsWith("zh", StringComparison.OrdinalIgnoreCase)
            ? step.LabelZh
            : step.LabelEn;

    private string StatusDisplay(string status) => status switch
    {
        "recommended" => L["Cockpit.Status.Recommended"].Value,
        "recommended_edge" => L["Cockpit.Status.RecommendedEdge"].Value,
        "on_hold" => L["Cockpit.Status.OnHold"].Value,
        "pending_analysis" => L["Cockpit.Status.PendingAnalysis"].Value,
        "pending_visa" => L["Cockpit.Status.PendingVisa"].Value,
        "visa_uncertain" => L["Cockpit.Status.VisaUncertain"].Value,
        "applied" => L["Cockpit.Status.Applied"].Value,
        _ => HumanizeCode(status),
    };

    private string MatchDisplay(string? matchLevel)
    {
        if (string.IsNullOrWhiteSpace(matchLevel))
        {
            return string.Empty;
        }

        return matchLevel.Trim().ToLowerInvariant() switch
        {
            "high" or "strong" => L["Cockpit.Match.High"].Value,
            "medium" or "moderate" or "edge" => L["Cockpit.Match.Medium"].Value,
            "low" or "weak" => L["Cockpit.Match.Low"].Value,
            _ => HumanizeCode(matchLevel),
        };
    }

    private static string HumanizeCode(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return string.Empty;
        }

        var normalized = value.Replace('_', ' ').Replace('-', ' ').Trim();
        return CultureInfo.CurrentCulture.TextInfo.ToTitleCase(normalized);
    }

    private static bool IsStrongFit(CockpitRecentJob job) =>
        MatchLevelIs(job, "high", "strong") || IsStatus(job, "recommended");

    private static bool IsPossibleFit(CockpitRecentJob job) =>
        MatchLevelIs(job, "medium", "moderate", "edge") || IsStatus(job, "recommended_edge");

    private static bool IsNeedsReview(CockpitRecentJob job) =>
        IsStatus(job, "on_hold", "pending_analysis", "pending_visa", "visa_uncertain");

    private bool IsInLastThreeCalendarDays(CockpitRecentJob job)
    {
        var today = Metrics?.LocalToday ?? DateOnly.FromDateTime(DateTime.Today);
        var start = today.AddDays(-2);
        var jobDate = DateOnly.FromDateTime(job.CreatedAt.Date);

        return jobDate >= start && jobDate <= today;
    }

    private static int SemanticScore(CockpitRecentJob job) =>
        job.MatchScore ?? job.WinScore ?? -1;

    private static bool MatchLevelIs(CockpitRecentJob job, params string[] values) =>
        values.Any(value => string.Equals(job.MatchLevel, value, StringComparison.OrdinalIgnoreCase));

    private static bool IsStatus(CockpitRecentJob job, params string[] values) =>
        values.Any(value => string.Equals(job.StatusCode, value, StringComparison.OrdinalIgnoreCase));

    private static int ApplicationReadinessScore(CockpitRecentJob job)
    {
        var baseScore = job.WinScore ?? job.MatchScore ?? 35;
        if (baseScore <= 10)
        {
            baseScore *= 10;
        }

        if (IsStatus(job, "applied"))
        {
            baseScore = Math.Max(baseScore, 80);
        }
        else if (IsStatus(job, "recommended", "visa_uncertain"))
        {
            baseScore = Math.Max(baseScore, 72);
        }
        else if (IsStatus(job, "recommended_edge"))
        {
            baseScore = Math.Max(baseScore, 62);
        }
        else if (IsStatus(job, "pending_analysis", "pending_visa", "on_hold"))
        {
            baseScore = Math.Min(baseScore, 55);
        }

        return Math.Clamp(baseScore, 20, 100);
    }

    private static int ApplicationReadinessSortScore(CockpitRecentJob job) =>
        ApplicationReadinessScore(job) + (IsStatus(job, "applied") ? 8 : 0);

    private string ApplicationNextAction(CockpitRecentJob job)
    {
        if (IsStatus(job, "applied"))
        {
            return "Review follow-up timing and networking state.";
        }

        if (IsStatus(job, "recommended", "visa_uncertain") || IsStrongFit(job))
        {
            return string.IsNullOrWhiteSpace(job.PipelineFolder)
                ? "Initialize the application folder and prepare a role brief."
                : "Use the existing folder to tailor resume and next-touch evidence.";
        }

        if (IsStatus(job, "recommended_edge") || IsPossibleFit(job))
        {
            return "Confirm fit risk, then decide whether this stays in the active pool.";
        }

        if (IsNeedsReview(job))
        {
            return "Review missing evidence before spending tailoring time.";
        }

        return "Keep as reference unless new evidence changes the fit.";
    }

    private static bool ContainsAny(string value, params string[] needles) =>
        needles.Any(value.Contains);

    private static string NormalizeCommand(string value) =>
        value.Trim().ToLowerInvariant().Replace(" ", string.Empty);

    private string? FindCompanyFilter(string command, string normalizedCommand)
    {
        var companies = RecentJobs
            .Select(job => job.Company.Trim())
            .Where(company => !string.IsNullOrWhiteSpace(company))
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .ToList();

        foreach (var company in companies)
        {
            var normalizedCompany = NormalizeCommand(company);
            if (normalizedCommand.Contains(normalizedCompany))
            {
                return company;
            }
        }

        var tokens = ExtractSearchTokens(command);
        return companies.FirstOrDefault(company =>
        {
            var normalizedCompany = NormalizeCommand(company);
            return tokens.Any(token => token.Length >= 3 && normalizedCompany.Contains(token));
        });
    }

    private bool MatchesSemanticContent(CockpitRecentJob job)
    {
        var terms = BuildSemanticContentTerms(ActiveSemanticGridContentQuery, ActiveSemanticGridContentTerms);
        if (terms.Count == 0)
        {
            return true;
        }

        var searchable = BuildSemanticJobText(job);
        var normalizedSearchable = NormalizeSemanticContent(searchable);
        return terms.Any(term =>
        {
            var normalizedTerm = NormalizeSemanticContent(term);
            return normalizedTerm.Length > 0 && normalizedSearchable.Contains(normalizedTerm);
        });
    }

    private string BuildSemanticJobText(CockpitRecentJob job) =>
        string.Join(
            ' ',
            job.Company,
            job.Title,
            job.StatusCode,
            StatusDisplay(job.StatusCode),
            job.MatchLevel,
            MatchDisplay(job.MatchLevel),
            job.JudgementSummary);

    private static string? SanitizeSemanticContentQuery(string? query)
    {
        if (string.IsNullOrWhiteSpace(query))
        {
            return null;
        }

        var value = string.Join(' ', query.Split((char[]?)null, StringSplitOptions.RemoveEmptyEntries));
        return value.Length <= 80 ? value : value[..80];
    }

    private static IReadOnlyList<string> BuildSemanticContentTerms(
        string? query,
        IEnumerable<string> rawTerms)
    {
        var terms = new List<string>();

        AddTerm(query);
        foreach (var term in rawTerms)
        {
            AddTerm(term);
        }

        foreach (var token in ExtractSearchTokens(query ?? string.Empty))
        {
            AddTerm(token);
        }

        for (var index = 0; index < terms.Count && terms.Count < 24; index++)
        {
            foreach (var alias in ExpandSemanticContentTerm(terms[index]))
            {
                AddTerm(alias);
            }
        }

        return terms.Take(24).ToList();

        void AddTerm(string? rawTerm)
        {
            var term = SanitizeSemanticContentTerm(rawTerm);
            if (term is null)
            {
                return;
            }

            if (!terms.Contains(term, StringComparer.OrdinalIgnoreCase))
            {
                terms.Add(term);
            }
        }
    }

    private static string? SanitizeSemanticContentTerm(string? rawTerm)
    {
        if (string.IsNullOrWhiteSpace(rawTerm))
        {
            return null;
        }

        var term = string.Join(' ', rawTerm.Split((char[]?)null, StringSplitOptions.RemoveEmptyEntries));
        if (term.Length > 40)
        {
            term = term[..40];
        }

        var normalized = NormalizeSemanticContent(term);
        if (normalized.Length < 2 || SemanticContentStopWords.Contains(normalized))
        {
            return null;
        }

        return term;
    }

    private static SemanticContentQuery? TryCreateLocalContentQuery(string command, string normalizedCommand)
    {
        var terms = new List<string>();

        foreach (var alias in SemanticContentAliases)
        {
            if (normalizedCommand.Contains(alias.Key))
            {
                terms.Add(alias.Key);
                terms.AddRange(alias.Value);
            }
        }

        if (terms.Count == 0 &&
            ContainsAny(normalizedCommand, "相關", "職缺", "工作", "role", "roles", "job", "jobs", "jd", "about"))
        {
            terms.AddRange(ExtractSearchTokens(command));
        }

        var contentTerms = BuildSemanticContentTerms(command, terms);
        if (contentTerms.Count == 0)
        {
            return null;
        }

        return new SemanticContentQuery(SanitizeSemanticContentQuery(command), contentTerms);
    }

    private static IEnumerable<string> ExpandSemanticContentTerm(string term)
    {
        var normalized = NormalizeSemanticContent(term);
        foreach (var alias in SemanticContentAliases)
        {
            if (normalized.Contains(alias.Key))
            {
                foreach (var expanded in alias.Value)
                {
                    yield return expanded;
                }
            }
        }
    }

    private static string NormalizeSemanticContent(string value)
    {
        var builder = new List<char>();
        foreach (var character in value.ToLowerInvariant())
        {
            if (char.IsLetterOrDigit(character))
            {
                builder.Add(character);
            }
        }

        return new string(builder.ToArray());
    }

    private static List<string> ExtractSearchTokens(string command)
    {
        var tokens = new List<string>();
        var token = new List<char>();

        foreach (var character in command.ToLowerInvariant())
        {
            if (char.IsAsciiLetterOrDigit(character))
            {
                token.Add(character);
                continue;
            }

            AddToken();
        }

        AddToken();
        return tokens;

        void AddToken()
        {
            if (token.Count == 0)
            {
                return;
            }

            tokens.Add(new string(token.ToArray()));
            token.Clear();
        }
    }


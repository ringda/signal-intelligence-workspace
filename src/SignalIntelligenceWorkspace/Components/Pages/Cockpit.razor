    private enum SemanticGridFilter
    {
        All,
        StrongFit,
        PossibleFit,
        NeedsReview,
        Applied,
    }

    private enum SemanticGridDateWindow
    {
        None,
        LastThreeDays,
    }

    private enum SemanticGridSort
    {
        None,
        Newest,
        Company,
        FitScore,
    }

    private enum SemanticGridParseSource
    {
        LocalRules,
        Ai,
    }

    private readonly record struct SemanticGridParseResult(
        bool Matched,
        bool Clear,
        SemanticGridFilter? Filter,
        SemanticGridDateWindow? DateWindow,
        SemanticGridSort? Sort,
        string? Company,
        string? ContentQuery,
        IReadOnlyList<string> ContentTerms)
    {
        public static SemanticGridParseResult Match(
            SemanticGridFilter? filter,
            SemanticGridDateWindow? dateWindow,
            SemanticGridSort? sort,
            string? company,
            string? contentQuery,
            IReadOnlyList<string> contentTerms) =>
            new(true, false, filter, dateWindow, sort, company, contentQuery, contentTerms);

        public static SemanticGridParseResult ForClear() =>
            new(true, true, null, null, null, null, null, []);

        public static SemanticGridParseResult NoMatch() =>
            new(false, false, null, null, null, null, null, []);
    }

    private sealed record SemanticContentQuery(string? Query, IReadOnlyList<string> Terms);

    private readonly record struct SemanticGridParseAttempt(
        SemanticGridParseResult Result,
        SemanticGridParseSource Source,
        string? AiReason,
        string? AiWarning,
        string ProviderName)
    {
        public static SemanticGridParseAttempt Local(
            SemanticGridParseResult result,
            string? aiWarning = null,
            string providerName = "AI") =>
            new(result, SemanticGridParseSource.LocalRules, null, aiWarning, providerName);

        public static SemanticGridParseAttempt Ai(
            SemanticGridParseResult result,
            string? reason,
            string providerName) =>
            new(result, SemanticGridParseSource.Ai, reason, null, providerName);
    }

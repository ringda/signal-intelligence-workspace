    private static string ProgressWidth(long actual, int target)
    {
        if (target <= 0)
        {
            return "0%";
        }

        return $"{Math.Clamp((double)actual / target, 0, 1) * 100:0}%";
    }

    private string SemanticGridSummary
    {
        get
        {
            var parts = new List<string>();
            if (ActiveSemanticGridFilter is not SemanticGridFilter.All)
            {
                parts.Add(ActiveSemanticGridFilterLabel);
            }

            if (!string.IsNullOrWhiteSpace(ActiveSemanticGridCompany))
            {
                parts.Add(L["Cockpit.Semantic.Filter.Company", ActiveSemanticGridCompany].Value);
            }

            if (HasSemanticGridContent)
            {
                parts.Add(L["Cockpit.Semantic.Filter.Content", ActiveSemanticGridContentLabel].Value);
            }

            if (ActiveSemanticGridDateWindow is not SemanticGridDateWindow.None)
            {
                parts.Add(ActiveSemanticGridDateWindowLabel);
            }

            if (ActiveSemanticGridSort is not SemanticGridSort.None)
            {
                parts.Add(ActiveSemanticGridSortLabel);
            }

            return parts.Count == 0
                ? L["Cockpit.Semantic.All"].Value
                : string.Join(" + ", parts);
        }
    }

    private string ActiveSemanticGridContentLabel
    {
        get
        {
            if (!string.IsNullOrWhiteSpace(ActiveSemanticGridContentQuery))
            {
                return ActiveSemanticGridContentQuery;
            }

            return string.Join(", ", ActiveSemanticGridContentTerms.Take(3));
        }
    }


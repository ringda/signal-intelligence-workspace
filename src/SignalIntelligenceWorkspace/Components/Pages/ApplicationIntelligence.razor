        string Value,
        string Label,
        string Detail,
        bool Primary,
        IReadOnlyList<MetricBreakdown>? Breakdown = null);

    private sealed record MetricBreakdown(string Label, string Value);

    private sealed record FunnelStep(string Value, string Label, string Detail);

    private sealed record PipelineStep(string Order, string Label, string State, double Progress);

    private sealed record ApplicationCase(
        string Company,
        string Role,
        string Decision,
        string Tone,
        string CorrectPool,
        int EvidenceScore,
        int ReadinessScore,
        string RoleContract,
        string MustProve,
        string CannotBorrow,
        string NextAction)
    {
        public string SourceLabel { get; init; } = string.Empty;
        public string SourceDetail { get; init; } = string.Empty;
        public string FitEvidence { get; init; } = string.Empty;
        public string ArtifactEvidence { get; init; } = string.Empty;
        public string LearningHook { get; init; } = string.Empty;
        public IReadOnlyList<CaseCheckpoint> Checkpoints { get; init; } = [];
    }

    private sealed record CaseCheckpoint(string Label, string State, string Tone, string Evidence);

    private sealed record LearningItem(string Signal, string Title, string Detail, string Tone);

    public sealed record DecisionScore(string Segment, int SignalShare, int Readiness);

@page "/"
@page "/home"
@layout PublicLayout

<PageTitle>Candidate Go-to-Market Pipeline | Johanna Fan</PageTitle>

<main class="public-home" data-testid="candidate-gtm-page">
    <section class="hero" id="top" aria-labelledby="public-home-title">
        <div class="hero-copy">
            <p class="eyebrow">Live GTM pipeline context</p>
            <h1 id="public-home-title">Candidate Go-to-Market Pipeline</h1>
            <p class="lead">
                I run my job search as a live candidate GTM pipeline, turning broad market and role
                signals into <strong>fit decisions, role-relevant proof, and tracked outreach</strong>
                that helps hiring teams quickly see where I can contribute.
            </p>

            <div class="proof-strip" aria-label="System proof points" data-testid="public-kpi-strip">
                <div class="proof">
                    <strong>20K+</strong>
                    <span>job-market signals screened with review rules</span>
                </div>
                <div class="proof">
                    <strong>6</strong>
                    <span>repeatable gates from signal to outreach review</span>
                </div>
                <div class="proof">
                    <strong>1</strong>
                    <span>loop connecting proof, outreach, and learning</span>
                </div>
            </div>
        </div>

        <div class="hero-visual" aria-label="Animated system map">
            <div class="system-map">
                <canvas id="flowCanvas" aria-hidden="true"></canvas>
                <div class="map-caption">
                    <span>Job signals</span>
                    <span>People signals</span>
                    <span>Evidence</span>
                    <span>Human review</span>
                    <span>Write-back</span>
                </div>
            </div>
        </div>
    </section>

    <section class="band-ink" id="workflow" aria-labelledby="public-workflow-title">
        <div class="section-inner">
            <p class="section-kicker">Workflow</p>
            <h2 id="public-workflow-title">Quality over quantity.</h2>
            <p class="section-text">
                A high-quality application is not just a submission. It is selected with care, tailored
                to the role, backed by proof, sent through a credible path, and reviewed for what should
                change next.
            </p>
            <p class="section-text roadmap-lead">Roadmap for each application</p>

            <div class="workflow" aria-label="Roadmap for each application">
                @foreach (var step in WorkflowSteps)
                {
                    <article class="workflow-step">
                        <span class="step-icon" aria-hidden="true">@WorkflowIcon(step.Number)</span>
                        <span class="step-number">@step.Number.ToString("00")</span>
                        <h3>@step.Title</h3>
                        <span class="step-dot" aria-hidden="true"></span>
                    </article>
                }
            </div>
        </div>
    </section>

    <section class="band-white" id="reliability" aria-labelledby="public-reliability-title">
        <div class="section-inner grid-2">
            <div>
                <p class="section-kicker">Reliability layer</p>
                <h2 id="public-reliability-title">Context / Knowledge / Tools keep this AI-assisted workflow from becoming random prompting.</h2>
                <p class="section-text">
                    All three have to stay in sync. AI can structure research, pressure-test wording,
                    and surface gaps; source checks, human review, and write-back decide what becomes
                    a real claim or next action.
                </p>
            </div>

            <div class="belief-list">
                @foreach (var layer in ReliabilityLayers)
                {
                    <div class="belief">
                        <b>@layer.Name</b>
                        <p>@layer.Detail</p>
                    </div>
                }
            </div>
        </div>
    </section>

    <section class="band-white" id="marketing-fit" aria-labelledby="public-marketing-title">
        <div class="section-inner">
            <p class="section-kicker">Marketing Fit</p>
            <h2 id="public-marketing-title">Why it matters for Marketing / GTM analytics</h2>
            <p class="section-text">
                That reliability layer is what makes the pipeline relevant to Marketing / GTM analytics:
                scattered signals become trusted context, a clearer readout, and a next action.
            </p>
            <p class="section-text">
                I am not claiming mature campaign ownership. I am showing the upstream work quality
                marketing analytics teams need: cleaner inputs, clearer definitions, visible review
                gates, and readouts that can support action.
            </p>

            <div class="capability-grid">
                @foreach (var card in MarketingFitCards)
                {
                    <article class="capability">
                        <span class="capability-mark" aria-hidden="true"></span>
                        <h3>@card.Title</h3>
                        <p>@card.Detail</p>
                    </article>
                }
            </div>

            <div class="split-list">
                <div class="role-block">
                    <h3>What this proves</h3>
                    <ul>
                        <li>I can turn noisy business signals into structured, reviewable context.</li>
                        <li>I can keep source, decision criteria, and handoff visible across a workflow.</li>
                        <li>I can use AI as a disciplined quality layer, not a black-box shortcut.</li>
                    </ul>
                    <p class="role-note">
                        That is the work quality I want to bring into Marketing / GTM analytics:
                        cleaner source context, safer review gates, clearer handoff, and judgment
                        that improves with each cycle.
                    </p>
                </div>
                <div class="role-block">
                    <h3>What it does not overclaim</h3>
                    <ul>
                        <li>It is not production CRM administration or campaign ownership.</li>
                        <li>It is not a substitute for learning the team's actual marketing motion.</li>
                    </ul>
                </div>
            </div>
        </div>
    </section>

    <section class="band-white" id="conversation" aria-labelledby="public-conversation-title">
        <div class="section-inner">
            <p class="section-kicker">Conversation use</p>
            <h2 id="public-conversation-title">A concise way to explain the pipeline after someone connects.</h2>
            <div class="reply-box">
                <p class="section-text">
                    The page gives context without making the other person feel like one item in a campaign.
                    It works best when paired with a small, role-specific question about how their team uses
                    marketing, GTM, customer, or revenue signals to decide what happens next.
                </p>
                <div class="message" aria-label="Sample networking message">
                    <p>
                        Hi [Name], thanks for connecting. I am building toward marketing / GTM analytics roles,
                        especially the part where messy customer, campaign, or market signals become clearer
                        reporting and next-step decisions.
                    </p>
                    <p>
                        I put together a short context page on a quality-over-quantity application pipeline I use
                        to practice that work: role screening, source checks, evidence translation, official
                        application, stakeholder outreach, tracking, and write-back.
                    </p>
                    <p>
                        From your view, where would this kind of judgment-building profile be useful on a
                        marketing or GTM analytics team?
                    </p>
                </div>
            </div>
        </div>
    </section>

    <footer class="footer">
        <div class="footer-inner">
            <span>Johanna Fan · Marketing / GTM / Customer Signal Analytics</span>
            <div class="footer-actions" aria-label="Contact links">
                <span>Built as a concise context page for networking conversations.</span>
                <a class="contact-link" href="https://linkedin.com/in/xxu09" target="_blank" rel="noreferrer">
                    <span class="contact-icon" aria-hidden="true">in</span>
                    <span>LinkedIn</span>
                </a>
                <a class="contact-link" href="mailto:xxfan9@gmail.com">
                    <span class="contact-icon" aria-hidden="true">@@</span>
                    <span>Email</span>
                </a>
            </div>
        </div>
    </footer>
</main>

@code {
    private static readonly IReadOnlyList<PipelineStep> WorkflowSteps =
    [
        new(1, "Find the right role", "Screen the market for fit, constraints, audience, and proof density before spending tailoring time."),
        new(2, "Tailor the resume to the JD", "Translate source-backed experience into the role's language without inventing claims."),
        new(3, "Prepare proof", "Package work samples, metrics, and system evidence into a hiring-manager-readable story."),
        new(4, "Apply", "Keep the official submission and status trail distinct from draft material and experiments."),
        new(5, "Connect with relevant people", "Use low-pressure questions tied to real work objects, team context, or handoff reality."),
        new(6, "Improve the next cycle", "Review what changed, what got a response, what was overfit, and what should be reused.")
    ];

    private static readonly IReadOnlyList<ReliabilityLayer> ReliabilityLayers =
    [
        new(
            "Context",
            "What world each opportunity is in: role, company, sources, status, constraints, gaps, and next action.",
            "What world each opportunity is in: role, company, sources, status, constraints, gaps, and next action."),
        new(
            "Knowledge",
            "What judgment can be reused: fit standards, correct pool, defensible proof, claim boundaries, quality gates, and exception rules.",
            "What judgment can be reused: fit standards, correct pool, defensible proof, claim boundaries, quality gates, and exception rules."),
        new(
            "Tools",
            "What can act under control: AI research and drafting, tracker, source checks, review gates, submission records, and write-back routines.",
            "What can act under control: AI research and drafting, tracker, source checks, review gates, submission records, and write-back routines.")
    ];

    private static readonly IReadOnlyList<MarketingFitCard> MarketingFitCards =
    [
        new("Analysis-ready inputs", "Source fields, status definitions, validation needs, and evidence gaps become visible before reporting."),
        new("KPI definitions and reporting logic", "Define what each metric counts, which source or status it trusts, and what action the readout should support before it becomes a dashboard."),
        new("Stakeholder handoff", "Each artifact is written for a reader: recruiter, peer, manager, analyst, or cross-functional partner."),
        new("Review-gated AI", "AI structures and drafts. Human checkpoints decide what gets sent, written back, or treated as true.")
    ];

    private static RenderFragment WorkflowIcon(int number) => number switch
    {
        1 => @<svg viewBox="0 0 24 24">
            <circle cx="11" cy="11" r="7"></circle>
            <path d="m20 20-3.5-3.5"></path>
        </svg>,
        2 => @<svg viewBox="0 0 24 24">
            <path d="M14 2H7a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V7Z"></path>
            <path d="M14 2v5h5"></path>
            <path d="M8 13h8"></path>
            <path d="M8 17h6"></path>
        </svg>,
        3 => @<svg viewBox="0 0 24 24">
            <path d="M14 2H7a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V7Z"></path>
            <path d="M14 2v5h5"></path>
            <path d="m9 15 2 2 4-5"></path>
        </svg>,
        4 => @<svg viewBox="0 0 24 24">
            <path d="m22 2-7 20-4-9-9-4Z"></path>
            <path d="M22 2 11 13"></path>
        </svg>,
        5 => @<svg viewBox="0 0 24 24">
            <path d="M16 21v-2a4 4 0 0 0-4-4H7a4 4 0 0 0-4 4v2"></path>
            <circle cx="9.5" cy="7" r="4"></circle>
            <path d="M17 11h4"></path>
            <path d="M19 9v4"></path>
        </svg>,
        6 => @<svg viewBox="0 0 24 24">
            <path d="M3 12a9 9 0 0 1 15.5-6.2L21 8"></path>
            <path d="M21 3v5h-5"></path>
            <path d="M21 12a9 9 0 0 1-15.5 6.2L3 16"></path>
            <path d="M3 21v-5h5"></path>
        </svg>,
        _ => @<svg viewBox="0 0 24 24">
            <circle cx="12" cy="12" r="8"></circle>
        </svg>
    };

    private sealed record PipelineStep(int Number, string Title, string Detail);

    private sealed record ReliabilityLayer(string Name, string Summary, string Detail);

    private sealed record MarketingFitCard(string Title, string Detail);
}

                        <span>Azure App Service</span>
                    </li>
                </ul>
            </div>

            <div class="implementation-map" aria-label="Implementation relationship map">
                <article class="implementation-node node-frontend">
                    <span class="node-icon node-icon-browser" aria-hidden="true">

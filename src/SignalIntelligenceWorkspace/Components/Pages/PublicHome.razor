</main>

@code {
    private const int MaxFeedbackLength = 600;

    [Parameter]
    public string? DeliveryToken { get; set; }

    private string SelectedFeedbackType { get; set; } = "most-useful";

    private string FeedbackMessage { get; set; } = string.Empty;

    private string FeedbackWebsite { get; set; } = string.Empty;

    private string? FeedbackError { get; set; }

    private string? FeedbackSuccess { get; set; }

    private bool IsSubmittingFeedback { get; set; }

    private string FeedbackButtonText => IsSubmittingFeedback ? "Sending..." : "Send a quick read";

    private FrontstageTokenContext? DeliveryContext { get; set; }

    private string DeliveryLanguage { get; set; } = "en";

    private string? LastResolvedDeliveryKey { get; set; }

    private string? LastTrackedDeliveryKey { get; set; }

    private string? LastAnonymousPageViewKey { get; set; }

    private static readonly IReadOnlyList<FeedbackOption> FeedbackOptions =
    [
        new("most-useful", "Most useful"),
        new("least-relevant", "Least relevant"),
        new("best-fit-team", "Best-fit team")
    ];

    private sealed record FeedbackOption(string Value, string Label);

    protected override async Task OnParametersSetAsync()
    {
        DeliveryLanguage = GetRequestedLanguage();

        if (string.IsNullOrWhiteSpace(DeliveryToken))
        {
            DeliveryContext = null;
            LastResolvedDeliveryKey = null;
            await LogAnonymousPageViewOnceAsync();
            return;
        }

        var deliveryKey = $"{DeliveryToken}|{DeliveryLanguage}";
        if (string.Equals(deliveryKey, LastResolvedDeliveryKey, StringComparison.Ordinal))
        {
            return;
        }

        LastResolvedDeliveryKey = deliveryKey;

        var httpContext = HttpContextAccessor.HttpContext;
        DeliveryContext = await FrontstageDelivery.ResolveAsync(new FrontstageDeliveryRequest(
            DeliveryToken,
            DeliveryLanguage,
            httpContext?.Request.Headers[Microsoft.Net.Http.Headers.HeaderNames.Referer].ToString(),
            httpContext?.Request.Headers[Microsoft.Net.Http.Headers.HeaderNames.UserAgent].ToString(),
            httpContext is not null && HttpMethods.IsGet(httpContext.Request.Method)));
    }

    private async Task LogAnonymousPageViewOnceAsync()
    {
        var httpContext = HttpContextAccessor.HttpContext;
        var pagePath = httpContext?.Request.Path.Value ?? "/";
        var trackingKey = $"anonymous|{pagePath}|{DeliveryLanguage}";
        if (string.Equals(trackingKey, LastAnonymousPageViewKey, StringComparison.Ordinal))
        {
            return;
        }

        LastAnonymousPageViewKey = trackingKey;
        await FrontstageDelivery.LogAnonymousPageViewAsync(new FrontstageAnonymousPageViewRequest(
            pagePath,
            DeliveryLanguage,
            httpContext?.Request.Headers[Microsoft.Net.Http.Headers.HeaderNames.Referer].ToString(),
            httpContext?.Request.Headers[Microsoft.Net.Http.Headers.HeaderNames.UserAgent].ToString(),
            httpContext is not null && HttpMethods.IsGet(httpContext.Request.Method)));
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (DeliveryContext is null || string.IsNullOrWhiteSpace(DeliveryToken))
        {
            return;
        }

        var trackingKey = $"{DeliveryToken}|{DeliveryLanguage}";
        if (string.Equals(trackingKey, LastTrackedDeliveryKey, StringComparison.Ordinal))
        {
            return;
        }

        LastTrackedDeliveryKey = trackingKey;
        await JS.InvokeVoidAsync(
            "frontstageTracking.watchSections",
            new FrontstageTrackingClientRequest(
                DeliveryToken,
                DeliveryLanguage,
                "/api/frontstage/section-view",
                "/api/frontstage/click"));
    }

    private string GetRequestedLanguage()
    {
        var uri = Navigation.ToAbsoluteUri(Navigation.Uri);
        var query = Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(uri.Query);
        return query.TryGetValue("lang", out var language)
            ? PostgresFrontstageDeliveryResolver.NormalizeLanguage(language.ToString())
            : "en";
    }

    private void OnFeedbackMessageChanged(string value)
    {
        FeedbackMessage = value;
        FeedbackError = null;
        FeedbackSuccess = null;
    }

    private async Task SubmitFeedbackAsync()
    {
        FeedbackError = null;
        FeedbackSuccess = null;

        var trimmedMessage = FeedbackMessage.Trim();
        if (string.IsNullOrWhiteSpace(trimmedMessage))
        {
            FeedbackError = "Add a short note first.";
            return;
        }

        if (trimmedMessage.Length > MaxFeedbackLength)
        {
            FeedbackError = "Keep the note under 600 characters.";
            return;
        }

        if (!string.IsNullOrWhiteSpace(FeedbackWebsite))
        {
            FeedbackMessage = string.Empty;
            FeedbackWebsite = string.Empty;
            FeedbackSuccess = "Received. Thank you for the quick read.";
            return;
        }

        IsSubmittingFeedback = true;
        try
        {
            var pagePath = new Uri(Navigation.Uri).PathAndQuery;
            await JS.InvokeAsync<PublicFeedbackClientResponse>("publicFeedback.submit",
                "/api/public-feedback",
                new PublicFeedbackClientRequest(
                SelectedFeedbackType,
                trimmedMessage,
                pagePath));

            FeedbackMessage = string.Empty;
            FeedbackSuccess = "Received. Thank you for the quick read.";
        }
        catch (JSException exception)
        {
            FeedbackError = string.IsNullOrWhiteSpace(exception.Message)
                ? "The feedback could not be saved. Please try again."
                : exception.Message;
        }
        catch
        {
            FeedbackError = "The feedback could not be saved. Please try again.";
        }
        finally
        {
            IsSubmittingFeedback = false;
        }
    }

    private sealed record PublicFeedbackClientRequest(
        string FeedbackType,
        string Message,
        string PagePath);

    private sealed record PublicFeedbackClientResponse(
        string Id,
        DateTimeOffset SubmittedAt);

    private sealed record FrontstageTrackingClientRequest(
        string Token,
        string Language,
        string Endpoint,
        string ClickEndpoint);
}

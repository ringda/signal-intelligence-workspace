@page "/"
@page "/home"
@layout PublicLayout

<PageTitle>Candidate Go-to-Market Pipeline | Johanna Fan</PageTitle>

<main class="public-home public-proof-dashboard" data-testid="public-proof-dashboard">
    <section class="public-dashboard-hero" aria-labelledby="public-home-title">
        <div class="public-dashboard-copy">
            <p class="public-kicker">Johanna Fan | Marketing / GTM / Customer Signal Analytics</p>
            <h1 id="public-home-title">Candidate Go-to-Market Pipeline</h1>
            <p class="public-lede">
                I run my job search as a live candidate GTM pipeline, turning broad market and role
                signals into <strong>fit decisions, role-relevant proof, and tracked outreach</strong>
                that help hiring teams quickly see where I can contribute.
            </p>
            <div class="public-hero-notes" aria-label="Pipeline positioning">
                <span>Quality over quantity</span>
                <span>Review-gated AI</span>
                <span>Dashboard-backed proof</span>
            </div>
        </div>

        <aside class="public-governance-card" aria-label="Public data boundary">
            <span>Public boundary</span>
            <strong>Telerik dashboard proof without private cockpit detail.</strong>
            <p>
                This page uses sanitized aggregates, synthetic timeline rows, and public-safe work
                patterns. Raw applications, outreach, company records, private notes, and HubSpot data
                stay behind authenticated routes.
            </p>
        </aside>
    </section>

    <section class="public-kpi-strip" aria-label="Public-safe pipeline metrics" data-testid="public-kpi-strip">
        @foreach (var metric in Metrics)
        {
            <article class="public-kpi">
                <span>@metric.Label</span>
                <strong>@metric.Value</strong>
                <p>@metric.Detail</p>
            </article>
        }
    </section>

    <section id="proof" class="public-dashboard-grid" aria-labelledby="public-proof-title">
        <div class="public-panel public-chart-panel" data-testid="public-proof-chart">
            <div class="public-section-head">
                <p class="public-kicker">Telerik dashboard proof surface</p>
                <h2 id="public-proof-title">Sanitized candidate GTM flow</h2>
                <p>
                    The chart keeps the proof inspectable: broad signals become screened opportunities,
                    tailored proof, reviewed outreach, and learning loops without exposing source rows.
                </p>
            </div>

            <TelerikChart Height="310px">
                <ChartSeriesItems>
                    <ChartSeries Type="@ChartSeriesType.Column"
                                 Data="@StageAggregates"
                                 Field="@nameof(PipelineAggregate.SignalVolume)"
                                 CategoryField="@nameof(PipelineAggregate.Stage)"
                                 Name="Public signal volume" />
                    <ChartSeries Type="@ChartSeriesType.Line"
                                 Data="@StageAggregates"
                                 Field="@nameof(PipelineAggregate.ReviewedItems)"
                                 CategoryField="@nameof(PipelineAggregate.Stage)"
                                 Name="Human-reviewed items" />
                </ChartSeriesItems>
                <ChartValueAxes>
                    <ChartValueAxis Min="0">
                        <ChartValueAxisLabels Format="{0}" />
                    </ChartValueAxis>
                </ChartValueAxes>
                <ChartLegend Position="@ChartLegendPosition.Bottom" Visible="true" />
            </TelerikChart>
        </div>

        <aside class="public-panel public-detail-panel" data-testid="public-proof-detail" aria-labelledby="public-detail-title">
            <div class="public-section-head">
                <p class="public-kicker">Selected proof row</p>
                <h2 id="public-detail-title">@SelectedProof.Theme</h2>
                <p>@SelectedProof.PublicEvidence</p>
            </div>

            <dl class="public-detail-list">
                <div>
                    <dt>Decision signal</dt>
                    <dd>@SelectedProof.Decision</dd>
                </div>
                <div>
                    <dt>Public status</dt>
                    <dd><span class="public-status @StatusClass(SelectedProof.Status)">@SelectedProof.Status</span></dd>
                </div>
                <div>
                    <dt>Next human review</dt>
                    <dd>@SelectedProof.NextReview</dd>
                </div>
                <div>
                    <dt>Confidence</dt>
                    <dd>@SelectedProof.Confidence</dd>
                </div>
            </dl>
        </aside>
    </section>

    <section id="workflow" class="public-content-band public-workflow-band" aria-labelledby="public-workflow-title">
        <div class="public-section-head">
            <p class="public-kicker">Workflow</p>
            <h2 id="public-workflow-title">Quality over quantity, made repeatable</h2>
            <p>
                Each application moves through the same public-safe operating logic: choose the right
                opportunity, translate evidence for that role, review what can be claimed, and learn
                from the result before the next cycle.
            </p>
        </div>

        <ol class="public-roadmap-list" aria-label="Roadmap for each application">
            @foreach (var step in WorkflowSteps)
            {
                <li>
                    <span>@step.Number</span>
                    <div>
                        <h3>@step.Title</h3>
                        <p>@step.Detail</p>
                    </div>
                </li>
            }
        </ol>
    </section>

    <section id="reliability" class="public-content-band" aria-labelledby="public-reliability-title">
        <div class="public-split-copy">
            <div class="public-section-head">
                <p class="public-kicker">Reliability layer</p>
                <h2 id="public-reliability-title">Context, knowledge, and tools keep AI-assisted work reviewable</h2>
                <p>
                    AI can structure research, pressure-test wording, and surface gaps. Source checks,
                    human review, and writeback rules decide what becomes a real claim or next action.
                </p>
            </div>

            <div class="public-reliability-summary">
                <strong>What stays protected</strong>
                <p>
                    Private cockpit details never become public proof by default. The homepage shows
                    aggregate logic and inspected work patterns, not raw CRM or application records.
                </p>
            </div>
        </div>

        <div class="public-card-grid public-reliability-grid">
            @foreach (var layer in ReliabilityLayers)
            {
                <article class="public-info-card">
                    <span>@layer.Name</span>
                    <h3>@layer.Summary</h3>
                    <p>@layer.Detail</p>
                </article>
            }
        </div>
    </section>

    <section id="marketing-fit" class="public-content-band" aria-labelledby="public-marketing-title">
        <div class="public-section-head public-narrow-copy">
            <p class="public-kicker">Marketing / GTM analytics relevance</p>
            <h2 id="public-marketing-title">Noisy signals become trusted context, clearer readouts, and next actions</h2>
            <p>
                I am not claiming mature campaign ownership. I am showing upstream work quality that
                marketing analytics teams need: cleaner inputs, clearer definitions, visible review
                gates, and handoffs that can support action.
            </p>
        </div>

        <div class="public-card-grid public-marketing-grid">
            @foreach (var card in MarketingFitCards)
            {
                <article class="public-info-card">
                    <span>@card.Title</span>
                    <p>@card.Detail</p>
                </article>
            }
        </div>

        <div class="public-proof-boundary">
            <div>
                <h3>What this proves</h3>
                <p>
                    I can turn messy business signals into structured, reviewable context while keeping
                    sources, decision criteria, and handoff visible across the workflow.
                </p>
            </div>
            <div>
                <h3>What it does not overclaim</h3>
                <p>
                    This is not production CRM administration or a substitute for learning a team's
                    actual marketing motion. It is a disciplined proof surface for the work quality I
                    want to bring into that environment.
                </p>
            </div>
        </div>
    </section>

    <section class="public-panel public-grid-panel" aria-labelledby="public-grid-title" data-testid="public-proof-grid">
        <div class="public-section-head">
            <p class="public-kicker">Public-safe grid</p>
            <h2 id="public-grid-title">Inspectable proof rows, not private records</h2>
            <p>
                Rows describe reusable work patterns and judgment surfaces. Select a row to inspect the
                public detail panel above.
            </p>
        </div>

        <TelerikGrid Data="@ProofRows"
                     Height="360px"
                     Sortable="true"
                     Resizable="true"
                     SelectionMode="@GridSelectionMode.Single"
                     SelectedItems="@SelectedProofRows"
                     OnRowClick="@OnProofRowClick">
            <GridColumns>
                <GridColumn Field="@nameof(PublicProofRow.Theme)" Title="Proof Theme" Width="230px">
                    <Template>
                        @{
                            var row = (PublicProofRow)context;
                        }
                        <div class="public-grid-title">
                            <strong>@row.Theme</strong>
                            <span>@row.Scope</span>
                        </div>
                    </Template>
                </GridColumn>
                <GridColumn Field="@nameof(PublicProofRow.Decision)" Title="Decision Signal" Width="240px" />
                <GridColumn Field="@nameof(PublicProofRow.Status)" Title="Public Status" Width="150px">
                    <Template>
                        @{
                            var row = (PublicProofRow)context;
                        }
                        <span class="public-status @StatusClass(row.Status)">@row.Status</span>
                    </Template>
                </GridColumn>
                <GridColumn Field="@nameof(PublicProofRow.Confidence)" Title="Confidence" Width="130px" />
                <GridColumn Field="@nameof(PublicProofRow.NextReview)" Title="Next Review" Width="300px" />
            </GridColumns>
        </TelerikGrid>
    </section>

    <section id="roadmap" class="public-panel public-gantt-panel" aria-labelledby="public-gantt-title" data-testid="public-proof-gantt">
        <div class="public-section-head">
            <p class="public-kicker">Roadmap proof</p>
            <h2 id="public-gantt-title">Milestone track from signal to hiring conversation</h2>
            <p>
                The Gantt turns the workflow into a visible operating cadence. Dates are illustrative
                public milestones, not private application history.
            </p>
        </div>

        <TelerikGantt Data="@TimelineItems"
                      Height="360px"
                      Width="100%"
                      IdField="@nameof(PublicTimelineItem.Id)"
                      ParentIdField="@nameof(PublicTimelineItem.ParentId)"
                      TitleField="@nameof(PublicTimelineItem.Title)"
                      StartField="@nameof(PublicTimelineItem.Start)"
                      EndField="@nameof(PublicTimelineItem.End)"
                      PercentCompleteField="@nameof(PublicTimelineItem.PercentComplete)"
                      View="@GanttView.Month"
                      TreeListWidth="360px"
                      ColumnResizable="true"
                      Navigable="true"
                      ShowTooltip="true">
            <GanttViews>
                <GanttMonthView />
            </GanttViews>
            <GanttColumns>
                <GanttColumn Field="@nameof(PublicTimelineItem.Title)" Title="Pipeline Milestone" Expandable="true" Width="220px" />
                <GanttColumn Field="@nameof(PublicTimelineItem.SignalSurface)" Title="Signal Surface" Width="150px" />
                <GanttColumn Field="@nameof(PublicTimelineItem.ReviewGate)" Title="Review Gate" Width="170px" />
            </GanttColumns>
        </TelerikGantt>
    </section>

    <section id="conversation" class="public-content-band public-conversation-band" aria-labelledby="public-conversation-title">
        <div class="public-section-head">
            <p class="public-kicker">Conversation use</p>
            <h2 id="public-conversation-title">A concise context page for networking conversations</h2>
            <p>
                The page gives context without making the other person feel like one item in a campaign.
                It works best with a small question about how their team uses marketing, GTM, customer,
                or revenue signals to decide what happens next.
            </p>
        </div>

        <blockquote class="public-message-sample">
            <p>
                I am building toward marketing / GTM analytics roles, especially the part where messy
                customer, campaign, or market signals become clearer reporting and next-step decisions.
            </p>
            <p>
                From your view, where would this kind of judgment-building profile be useful on a
                marketing or GTM analytics team?
            </p>
        </blockquote>
    </section>
</main>

@code {
    private static readonly IReadOnlyList<PublicMetric> Metrics =
    [
        new("Reviewed signal pool", "20K+", "Job-market signals screened with rules, source checks, and public-safe aggregation."),
        new("Repeatable gates", "6", "A consistent path from role screening to proof, outreach review, and next-cycle learning."),
        new("Learning loop", "1", "Evidence, outreach, application status, and judgment stay connected instead of becoming one-off notes."),
        new("Auto-write policy", "0", "No assistant output writes to private systems without a human review and explicit confirmation gate.")
    ];

    private static readonly IReadOnlyList<PipelineAggregate> StageAggregates =
    [
        new("Screen", 128, 92),
        new("Tailor", 96, 84),
        new("Proof", 72, 66),
        new("Apply", 48, 44),
        new("Connect", 34, 31),
        new("Learn", 26, 26)
    ];

    private static readonly IReadOnlyList<PipelineStep> WorkflowSteps =
    [
        new(1, "Find the right role", "Screen the market for fit, constraints, audience, and proof density before spending tailoring time."),
        new(2, "Tailor the resume to the JD", "Translate source-backed experience into the role's language without inventing claims."),
        new(3, "Prepare proof", "Package work samples, metrics, and system evidence into a hiring-manager-readable story."),
        new(4, "Apply", "Keep the official submission and status trail distinct from draft material and experiments."),
        new(5, "Connect with relevant people", "Use low-pressure questions tied to real work objects, team context, or handoff reality."),
        new(6, "Improve the next cycle", "Review what changed, what got a response, what was overfit, and what should be reused.")
    ];

    private static readonly IReadOnlyList<ReliabilityLayer> ReliabilityLayers =
    [
        new(
            "Context",
            "Each opportunity stays in its task world.",
            "Role, company, source, status, constraints, gaps, and next action are tracked before a claim is made."),
        new(
            "Knowledge",
            "Reusable judgment has a source boundary.",
            "Fit standards, correct pools, defensible proof, quality gates, and exception rules can be reused without becoming folklore."),
        new(
            "Tools",
            "Action is controlled by review gates.",
            "AI research and drafting, tracker checks, source review, submission records, and writeback routines stay separated.")
    ];

    private static readonly IReadOnlyList<MarketingFitCard> MarketingFitCards =
    [
        new("Analysis-ready inputs", "Source fields, status definitions, validation needs, and evidence gaps become visible before reporting."),
        new("KPI definitions and reporting logic", "Each metric says what it counts, which source or status it trusts, and what action the readout should support."),
        new("Stakeholder handoff", "Artifacts are written for a reader: recruiter, peer, manager, analyst, or cross-functional partner."),
        new("Review-gated AI", "AI structures and drafts. Human checkpoints decide what gets sent, written back, or treated as true.")
    ];

    private static readonly IReadOnlyList<PublicProofRow> ProofRows =
    [
        new(
            "Candidate GTM operating system",
            "Role, company, and people signals are organized into a tracked path from market screening to hiring conversation.",
            "Fit, constraints, proof density, and next action become comparable decision fields.",
            "Ready",
            "High",
            "Refresh public aggregate after each verified private run.",
            "Pipeline"),
        new(
            "Marketing signal analytics",
            "Market, customer-language, campaign, and revenue-adjacent signals are summarized without source records.",
            "The strongest public proof is the reasoning path, not the private row.",
            "Ready",
            "High",
            "Keep one concise public example per proof theme.",
            "Analytics"),
        new(
            "KPI and reporting logic",
            "Dashboard rows show what each metric counts and which status or source it trusts.",
            "A readout is only useful when it names the action it should support.",
            "Ready",
            "High",
            "Keep metric definitions visible near the proof surface.",
            "Measurement"),
        new(
            "Stakeholder handoff",
            "Proof is translated for the reader rather than dumped as internal process.",
            "Recruiter, peer, manager, and analyst audiences need different evidence packaging.",
            "Ready",
            "High",
            "Pair each claim with a public-safe evidence category.",
            "Narrative"),
        new(
            "Review-gated AI",
            "Assistant outputs are drafts until reviewed and explicitly accepted.",
            "The boundary between analysis and writeback is part of the proof.",
            "Review gate",
            "High",
            "Keep private routes authenticated and public routes source-redacted.",
            "Reliability"),
        new(
            "Private CRM and cockpit boundary",
            "CRM readiness and application status can be represented as policy states and counts only.",
            "Raw records, notes, and writeback operations stay behind authentication.",
            "Guarded",
            "Medium",
            "Show proposal quality and governance, not record contents.",
            "Safety")
    ];

    private static readonly IReadOnlyList<PublicTimelineItem> TimelineItems =
    [
        new(1, null, "Find the right role", "Market/JD", "Fit screen", new DateTime(2026, 6, 1), new DateTime(2026, 6, 7), 1),
        new(2, null, "Tailor resume to JD", "Evidence", "Claim boundary", new DateTime(2026, 6, 6), new DateTime(2026, 6, 13), 0.92),
        new(3, null, "Prepare proof", "Portfolio", "Redaction check", new DateTime(2026, 6, 11), new DateTime(2026, 6, 18), 0.84),
        new(4, null, "Apply", "Submission", "Official record", new DateTime(2026, 6, 16), new DateTime(2026, 6, 22), 0.76),
        new(5, null, "Connect with relevant people", "Outreach", "Human review", new DateTime(2026, 6, 21), new DateTime(2026, 6, 28), 0.68),
        new(6, null, "Improve the next cycle", "Learning loop", "Writeback policy", new DateTime(2026, 6, 26), new DateTime(2026, 7, 3), 0.58)
    ];

    private PublicProofRow SelectedProof { get; set; } = ProofRows[0];

    private IEnumerable<PublicProofRow> SelectedProofRows => [SelectedProof];

    private Task OnProofRowClick(GridRowClickEventArgs args)
    {
        if (args.Item is PublicProofRow selected)
        {
            SelectedProof = selected;
        }

        return Task.CompletedTask;
    }

    private static string StatusClass(string status) => status switch
    {
        "Ready" => "public-status-ready",
        "Guarded" => "public-status-guarded",
        "Review gate" => "public-status-review",
        _ => "public-status-neutral"
    };

    private sealed record PublicMetric(string Label, string Value, string Detail);

    private sealed record PipelineAggregate(string Stage, int SignalVolume, int ReviewedItems);

    private sealed record PipelineStep(int Number, string Title, string Detail);

    private sealed record ReliabilityLayer(string Name, string Summary, string Detail);

    private sealed record MarketingFitCard(string Title, string Detail);

    private sealed record PublicProofRow(
        string Theme,
        string PublicEvidence,
        string Decision,
        string Status,
        string Confidence,
        string NextReview,
        string Scope);

    private sealed class PublicTimelineItem
    {
        public PublicTimelineItem()
        {
        }

        public PublicTimelineItem(
            int id,
            int? parentId,
            string title,
            string signalSurface,
            string reviewGate,
            DateTime start,
            DateTime end,
            double percentComplete)
        {
            Id = id;
            ParentId = parentId;
            Title = title;
            SignalSurface = signalSurface;
            ReviewGate = reviewGate;
            Start = start;
            End = end;
            PercentComplete = percentComplete;
        }

        public int Id { get; set; }

        public int? ParentId { get; set; }

        public string Title { get; set; } = string.Empty;

        public string SignalSurface { get; set; } = string.Empty;

        public string ReviewGate { get; set; } = string.Empty;

        public DateTime Start { get; set; }

        public DateTime End { get; set; }

        public double PercentComplete { get; set; }
    }
}

@page "/"
@page "/home"
@page "/r/{DeliveryToken}"
@layout PublicLayout
@using SignalIntelligenceWorkspace.Services.Frontstage
@inject IFrontstageDeliveryResolver FrontstageDelivery
@inject IPublicOperatingCadenceReader OperatingCadenceReader
@inject IHttpContextAccessor HttpContextAccessor
@inject NavigationManager Navigation
@inject IJSRuntime JS

<PageTitle>Candidate Go-to-Market Pipeline | Johanna Fan</PageTitle>

<main class="public-home" data-testid="candidate-gtm-page">
    <section class="hero" id="top" data-frontstage-section="hero" aria-labelledby="public-home-title">
        <div class="hero-copy">
            <p class="eyebrow">Live GTM pipeline context</p>
            <h1 id="public-home-title">Candidate Go-to-Market Pipeline</h1>
            <p class="lead">
                I use a Candidate Go-to-Market system to turn market signals, role context, and real
                conversations into <strong>clearer fit decisions, role-relevant proof, and context-aware
                follow-up</strong>. Each cycle sharpens the evidence and shows me what to learn next
                from the market.
            </p>

            <div class="proof-strip" aria-label="System proof points" data-testid="public-kpi-strip">
                <div class="proof">
                    <strong>20K+</strong>
                    <span>job-market signals screened with review rules</span>
                </div>
                <div class="proof">
                    <strong>6</strong>
                    <span>repeatable gates from signal to proof and follow-up</span>
                </div>
                <div class="proof">
                    <strong>1</strong>
                    <span>loop connecting market feedback, proof, and learning</span>
                </div>
            </div>
        </div>

        <div class="hero-visual" aria-label="Animated system map">
            <div class="system-map">
                <canvas id="flowCanvas" aria-hidden="true"></canvas>
                <div class="map-caption">
                    <span>Job signals</span>
                    <span>Role context</span>
                    <span>Evidence</span>
                    <span>Human review</span>
                    <span>Write-back</span>
                </div>
            </div>
        </div>
    </section>

    <section class="band-ink" id="workflow" data-frontstage-section="workflow" aria-labelledby="public-workflow-title">
        <div class="section-inner">
            <p class="section-kicker">Workflow</p>
            <h2 id="public-workflow-title">Quality over quantity.</h2>
            <p class="section-text">
                A high-quality application is not just a submission. It is selected with care, tailored
                to the role, backed by proof, sent through a credible path, and reviewed for what should
                change next.
            </p>
            <p class="section-text roadmap-lead">Operating rhythm</p>
            <p class="cadence-note">Recent cadence is shown as presence, not volume.</p>

            <div class="cadence-shell" aria-label="Operating rhythm across the candidate GTM loop">
                <TelerikStepper Value="@CadenceStepperValue"
                                Linear="false"
                                StepType="@StepperStepType.Labels"
                                Class="cadence-stepper">
                    <StepperSteps>
                        @foreach (var step in PublicOperatingCadenceDefinitions.Steps)
                        {
                            <StepperStep Label="@step.Label" />
                        }
                    </StepperSteps>
                </TelerikStepper>

                <TelerikGridLayout Class="cadence-grid"
                                   ColumnSpacing="8px"
                                   RowSpacing="8px">
                    <GridLayoutColumns>
                        <GridLayoutColumn Width="minmax(145px, 1.35fr)" />
                        @foreach (var day in CadenceDays)
                        {
                            <GridLayoutColumn Width="1fr" />
                        }
                    </GridLayoutColumns>
                    <GridLayoutRows>
                        <GridLayoutRow Height="34px" />
                        @foreach (var row in CadenceRows)
                        {
                            <GridLayoutRow Height="48px" />
                        }
                    </GridLayoutRows>
                    <GridLayoutItems>
                        <GridLayoutItem Row="1" Column="1" Class="cadence-grid-corner">
                            Recent
                        </GridLayoutItem>
                        @foreach (var day in CadenceDays)
                        {
                            <GridLayoutItem Row="1" Column="@(day.DayPosition + 1)" Class="cadence-grid-header">
                                <span>@day.WeekdayLabel</span>
                                @if (!string.IsNullOrWhiteSpace(day.DisplayDayKey))
                                {
                                    <small>@day.DisplayDayKey[5..]</small>
                                }
                            </GridLayoutItem>
                        }
                        @for (var rowIndex = 0; rowIndex < CadenceRows.Count; rowIndex++)
                        {
                            var row = CadenceRows[rowIndex];
                            var gridRow = rowIndex + 2;
                            <GridLayoutItem Row="@gridRow" Column="1" Class="cadence-row-label">
                                @row.Label
                            </GridLayoutItem>
                            @foreach (var day in CadenceDays)
                            {
                                var cell = FindCadenceCell(row, day.DayPosition);
                                <GridLayoutItem Row="@gridRow"
                                                Column="@(day.DayPosition + 1)"
                                                Class="@CadenceCellClass(cell.ActivityLevel)">
                                    <span aria-hidden="true"></span>
                                    <span class="sr-only">@row.Label @day.WeekdayLabel: @CadenceActivityLabel(cell.ActivityLevel)</span>
                                </GridLayoutItem>
                            }
                        }
                    </GridLayoutItems>
                </TelerikGridLayout>

                <article class="cadence-writeback-note">
                    <span>Write-back</span>
                    <p>Review notes feed back into source rules, proof boundaries, and next-action logic.</p>
                </article>
            </div>
        </div>
    </section>

    <section class="band-white" id="reliability" data-frontstage-section="reliability" aria-labelledby="public-reliability-title">
        <div class="section-inner grid-2 reliability-grid">
            <figure class="reliability-visual">
                <img
                    src="/public-home-reliability-engine.png"
                    alt="Incoming contexts flow into a company workflow engine where knowledge and skills turn judgment into repeatable steps." />
            </figure>

            <div class="reliability-copy">
                <p class="section-kicker">Reliability layer</p>
                <h2 id="public-reliability-title"><span>AI-assisted</span> skill layer</h2>
                <p class="section-text">
                    A workflow becomes more valuable when each run makes the next one sharper.
                </p>
                <p class="section-text">
                    After each role, company signal, or stakeholder question moves through the roadmap,
                    I use AI to <strong>externalize the judgment</strong> that usually stays in my head:
                    what mattered, what was missing, what could not be claimed, and where human review
                    changed the decision.
                </p>
                <p class="section-text">
                    Repeated patterns become <strong>one reusable AI skill</strong> for source order,
                    audience context, KPI questions, guardrails, review points, and write-back behavior.
                </p>
                <p class="section-text reliability-closing">
                    The next run does not start from a fresh prompt. It starts from a clearer method.
                </p>
            </div>
        </div>
    </section>

    <section class="band-white" id="marketing-fit" data-frontstage-section="marketing-fit" aria-labelledby="public-marketing-title">
        <div class="section-inner marketing-fit-layout">
            <div class="marketing-fit-copy">
                <p class="section-kicker">Marketing Fit</p>
                <h2 id="public-marketing-title">Why it matters for <span>Marketing / GTM analytics</span></h2>
                <p class="section-text">
                    Good marketing analytics depends on the work that happens <span class="copy-emphasis">before the dashboard</span>:
                    <strong>clean source context</strong>, <strong>meaningful audience logic</strong>,
                    <strong>focused KPI questions</strong>, and handoffs that turn reporting into clearer
                    <strong>campaign, channel, audience, or workflow decisions</strong>.
                </p>
                <p class="section-text">
                    This pipeline practices that same pattern. Each role, company read, or conversation
                    becomes a small GTM signal system: define the context, map the source, check the claim,
                    prepare useful, handoff-ready proof, and write back what the next cycle should learn.
                </p>
                <p class="section-text">
                    What I can own at this stage is the upstream work: source context, claim boundaries,
                    handoff-ready proof, and questions that make reporting useful. I am not claiming
                    production CRM administration or attribution ownership.
                </p>
            </div>

            <aside class="decision-map" aria-label="Marketing analytics decision map">
                <div class="decision-map-header">
                    <span class="decision-map-kicker">Before the dashboard</span>
                    <h3>Upstream work shapes decision quality</h3>
                </div>
                <ol class="decision-steps">
                    <li>
                        <span>01</span>
                        <strong>Clean source context</strong>
                    </li>
                    <li>
                        <span>02</span>
                        <strong>Meaningful audience logic</strong>
                    </li>
                    <li>
                        <span>03</span>
                        <strong>Focused KPI questions</strong>
                    </li>
                    <li>
                        <span>04</span>
                        <strong>Handoff-ready readout</strong>
                    </li>
                </ol>
                <div class="decision-outcomes">
                    <span>Turns into decisions about</span>
                    <div class="decision-chips" aria-label="Decision types">
                        <b>Campaign</b>
                        <b>Channel</b>
                        <b>Audience</b>
                        <b>Workflow</b>
                    </div>
                </div>
            </aside>
        </div>
    </section>

    <section class="band-white" id="conversation" data-frontstage-section="conversation" aria-labelledby="public-conversation-title">
        <div class="section-inner">
            <p class="section-kicker">Conversation</p>
            <h2 id="public-conversation-title">Where this work could fit</h2>
            <div class="reply-box">
                <p class="section-text">
                    If this way of working feels relevant to your team, I would value your read on where it fits
                    best: marketing analytics, GTM operations, customer signal work, reporting handoff, or another
                    part of the workflow.
                </p>
                <div class="message reply-card" aria-label="Send a quick read">
                    <p>A small reply is enough.</p>
                    <div class="feedback-form">
                        <div class="feedback-type" aria-label="Feedback type">
                            <TelerikRadioGroup Data="@FeedbackOptions"
                                               TextField="@nameof(FeedbackOption.Label)"
                                               ValueField="@nameof(FeedbackOption.Value)"
                                               @bind-Value="@SelectedFeedbackType"
                                               Layout="@RadioGroupLayout.Horizontal"
                                               AriaLabel="Choose a feedback type" />
                        </div>
                        <TelerikTextArea Value="@FeedbackMessage"
                                         ValueChanged="@OnFeedbackMessageChanged"
                                         Placeholder="A quick read in one or two sentences..."
                                         Rows="4"
                                         DebounceDelay="0"
                                         ResizeMode="@TextAreaResizeMode.Vertical"
                                         Width="100%"
                                         AriaLabel="Quick feedback message" />
                        <input class="feedback-honeypot"
                               aria-hidden="true"
                               tabindex="-1"
                               autocomplete="off"
                               @bind="FeedbackWebsite" />
                        <div class="feedback-meta" aria-live="polite">
                            <span>@FeedbackMessage.Length / 600</span>
                        </div>
                        @if (!string.IsNullOrWhiteSpace(FeedbackError))
                        {
                            <p class="feedback-status feedback-error" role="alert">@FeedbackError</p>
                        }
                        @if (!string.IsNullOrWhiteSpace(FeedbackSuccess))
                        {
                            <p class="feedback-status feedback-success" role="status">@FeedbackSuccess</p>
                        }
                        <span data-frontstage-click="feedback-submit">
                            <TelerikButton ButtonType="@ButtonType.Button"
                                           Class="feedback-submit"
                                           Enabled="@(!IsSubmittingFeedback)"
                                           OnClick="@SubmitFeedbackAsync">
                                @FeedbackButtonText
                            </TelerikButton>
                        </span>
                    </div>
                    <p>
                        Which part feels most useful, which part feels least relevant, or what kind of team
                        would know how to use this work well?
                    </p>
                </div>
            </div>
        </div>
    </section>

    <footer class="footer">
        <div class="footer-inner">
            <span>Johanna Fan · Marketing / GTM / Customer Signal Analytics</span>
            <div class="footer-actions" aria-label="Contact links">
                <span>Open to a quick read on where this work fits best.</span>
                <a class="contact-link" href="https://linkedin.com/in/xxu09" target="_blank" rel="noreferrer" data-frontstage-click="linkedin">
                    <span class="contact-icon" aria-hidden="true">in</span>
                    <span>LinkedIn</span>
                </a>
                <a class="contact-link" href="mailto:xxfan9@gmail.com" data-frontstage-click="email">
                    <span class="contact-icon" aria-hidden="true">@@</span>
                    <span>Email</span>
                </a>
            </div>
        </div>
    </footer>
</main>

@code {
    private const int MaxFeedbackLength = 600;

    [Parameter]
    public string? DeliveryToken { get; set; }

    private string SelectedFeedbackType { get; set; } = "most-useful";

    private string FeedbackMessage { get; set; } = string.Empty;

    private string FeedbackWebsite { get; set; } = string.Empty;

    private string? FeedbackError { get; set; }

    private string? FeedbackSuccess { get; set; }

    private bool IsSubmittingFeedback { get; set; }

    private string FeedbackButtonText => IsSubmittingFeedback ? "Sending..." : "Send a quick read";

    private FrontstageTokenContext? DeliveryContext { get; set; }

    private string DeliveryLanguage { get; set; } = "en";

    private string? LastResolvedDeliveryKey { get; set; }

    private string? LastTrackedDeliveryKey { get; set; }

    private string? LastAnonymousPageViewKey { get; set; }

    private PublicOperatingCadenceSnapshot? OperatingCadence { get; set; }

    private IReadOnlyList<PublicOperatingCadenceDay> CadenceDays =>
        OperatingCadence?.Days ?? PublicOperatingCadenceSnapshot.Fallback(DateTimeOffset.UtcNow).Days;

    private IReadOnlyList<PublicOperatingCadenceRow> CadenceRows =>
        OperatingCadence?.Rows ?? PublicOperatingCadenceSnapshot.Fallback(DateTimeOffset.UtcNow).Rows;

    private int CadenceStepperValue
    {
        get
        {
            var latestActiveRow = CadenceRows
                .Where(row => row.Cells.Any(cell => !string.Equals(cell.ActivityLevel, "none", StringComparison.Ordinal)))
                .Select(row => PublicOperatingCadenceDefinitions.Steps
                    .ToList()
                    .FindIndex(step => string.Equals(step.StepKey, row.StepKey, StringComparison.Ordinal)))
                .Where(index => index >= 0)
                .DefaultIfEmpty(0)
                .Max();

            return latestActiveRow;
        }
    }

    private static readonly IReadOnlyList<FeedbackOption> FeedbackOptions =
    [
        new("most-useful", "Most useful"),
        new("least-relevant", "Least relevant"),
        new("best-fit-team", "Best-fit team")
    ];

    private static PublicOperatingCadenceCell FindCadenceCell(PublicOperatingCadenceRow row, int dayPosition)
    {
        return row.Cells.FirstOrDefault(cell => cell.DayPosition == dayPosition)
            ?? new PublicOperatingCadenceCell(dayPosition, string.Empty, string.Empty, "none");
    }

    private static string CadenceCellClass(string activityLevel)
    {
        var normalized = string.Equals(activityLevel, "present", StringComparison.Ordinal)
            || string.Equals(activityLevel, "active", StringComparison.Ordinal)
            || string.Equals(activityLevel, "heavy", StringComparison.Ordinal)
            ? activityLevel
            : "none";

        return $"cadence-cell is-{normalized}";
    }

    private static string CadenceActivityLabel(string activityLevel) => activityLevel switch
    {
        "present" => "present",
        "active" => "active",
        "heavy" => "high activity",
        _ => "no recent activity",
    };

    private sealed record FeedbackOption(string Value, string Label);

    protected override async Task OnParametersSetAsync()
    {
        await LoadOperatingCadenceOnceAsync();

        DeliveryLanguage = GetRequestedLanguage();

        if (string.IsNullOrWhiteSpace(DeliveryToken))
        {
            DeliveryContext = null;
            LastResolvedDeliveryKey = null;
            await LogAnonymousPageViewOnceAsync();
            return;
        }

        var deliveryKey = $"{DeliveryToken}|{DeliveryLanguage}";
        if (string.Equals(deliveryKey, LastResolvedDeliveryKey, StringComparison.Ordinal))
        {
            return;
        }

        LastResolvedDeliveryKey = deliveryKey;

        var httpContext = HttpContextAccessor.HttpContext;
        DeliveryContext = await FrontstageDelivery.ResolveAsync(new FrontstageDeliveryRequest(
            DeliveryToken,
            DeliveryLanguage,
            httpContext?.Request.Headers[Microsoft.Net.Http.Headers.HeaderNames.Referer].ToString(),
            httpContext?.Request.Headers[Microsoft.Net.Http.Headers.HeaderNames.UserAgent].ToString(),
            httpContext is not null && HttpMethods.IsGet(httpContext.Request.Method)));
    }

    private async Task LoadOperatingCadenceOnceAsync()
    {
        if (OperatingCadence is not null)
        {
            return;
        }

        OperatingCadence = await OperatingCadenceReader.ReadAsync();
    }

    private async Task LogAnonymousPageViewOnceAsync()
    {
        var httpContext = HttpContextAccessor.HttpContext;
        var pagePath = httpContext?.Request.Path.Value ?? "/";
        var trackingKey = $"anonymous|{pagePath}|{DeliveryLanguage}";
        if (string.Equals(trackingKey, LastAnonymousPageViewKey, StringComparison.Ordinal))
        {
            return;
        }

        LastAnonymousPageViewKey = trackingKey;
        await FrontstageDelivery.LogAnonymousPageViewAsync(new FrontstageAnonymousPageViewRequest(
            pagePath,
            DeliveryLanguage,
            httpContext?.Request.Headers[Microsoft.Net.Http.Headers.HeaderNames.Referer].ToString(),
            httpContext?.Request.Headers[Microsoft.Net.Http.Headers.HeaderNames.UserAgent].ToString(),
            httpContext is not null && HttpMethods.IsGet(httpContext.Request.Method)));
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (DeliveryContext is null || string.IsNullOrWhiteSpace(DeliveryToken))
        {
            return;
        }

        var trackingKey = $"{DeliveryToken}|{DeliveryLanguage}";
        if (string.Equals(trackingKey, LastTrackedDeliveryKey, StringComparison.Ordinal))
        {
            return;
        }

        LastTrackedDeliveryKey = trackingKey;
        await JS.InvokeVoidAsync(
            "frontstageTracking.watchSections",
            new FrontstageTrackingClientRequest(
                DeliveryToken,
                DeliveryLanguage,
                "/api/frontstage/section-view",
                "/api/frontstage/click"));
    }

    private string GetRequestedLanguage()
    {
        var uri = Navigation.ToAbsoluteUri(Navigation.Uri);
        var query = Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(uri.Query);
        return query.TryGetValue("lang", out var language)
            ? PostgresFrontstageDeliveryResolver.NormalizeLanguage(language.ToString())
            : "en";
    }

    private void OnFeedbackMessageChanged(string value)
    {
        FeedbackMessage = value;
        FeedbackError = null;
        FeedbackSuccess = null;
    }

    private async Task SubmitFeedbackAsync()
    {
        FeedbackError = null;
        FeedbackSuccess = null;

        var trimmedMessage = FeedbackMessage.Trim();
        if (string.IsNullOrWhiteSpace(trimmedMessage))
        {
            FeedbackError = "Add a short note first.";
            return;
        }

        if (trimmedMessage.Length > MaxFeedbackLength)
        {
            FeedbackError = "Keep the note under 600 characters.";
            return;
        }

        if (!string.IsNullOrWhiteSpace(FeedbackWebsite))
        {
            FeedbackMessage = string.Empty;
            FeedbackWebsite = string.Empty;
            FeedbackSuccess = "Received. Thank you for the quick read.";
            return;
        }

        IsSubmittingFeedback = true;
        try
        {
            var pagePath = new Uri(Navigation.Uri).PathAndQuery;
            await JS.InvokeAsync<PublicFeedbackClientResponse>("publicFeedback.submit",
                "/api/public-feedback",
                new PublicFeedbackClientRequest(
                SelectedFeedbackType,
                trimmedMessage,
                pagePath));

            FeedbackMessage = string.Empty;
            FeedbackSuccess = "Received. Thank you for the quick read.";
        }
        catch (JSException exception)
        {
            FeedbackError = string.IsNullOrWhiteSpace(exception.Message)
                ? "The feedback could not be saved. Please try again."
                : exception.Message;
        }
        catch
        {
            FeedbackError = "The feedback could not be saved. Please try again.";
        }
        finally
        {
            IsSubmittingFeedback = false;
        }
    }

    private sealed record PublicFeedbackClientRequest(
        string FeedbackType,
        string Message,
        string PagePath);

    private sealed record PublicFeedbackClientResponse(
        string Id,
        DateTimeOffset SubmittedAt);

    private sealed record FrontstageTrackingClientRequest(
        string Token,
        string Language,
        string Endpoint,
        string ClickEndpoint);
}

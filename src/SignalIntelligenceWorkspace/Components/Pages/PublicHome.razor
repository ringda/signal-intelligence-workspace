                <article class="implementation-node node-hosting">
                    <span class="node-icon node-icon-cloud" aria-hidden="true">
                        <svg viewBox="0 0 48 48" role="presentation" focusable="false">
                            <path d="M16.5 36h19a8.5 8.5 0 0 0 .6-17 12 12 0 0 0-23-3.8A10.5 10.5 0 0 0 16.5 36Z" />
                        </svg>
                    </span>

@page "/"
@page "/home"
@layout PublicLayout

<PageTitle>Johanna Fan | GTM Signal Intelligence</PageTitle>

<main class="public-home public-proof-dashboard" data-testid="public-proof-dashboard">
    <section class="public-dashboard-hero" aria-labelledby="public-home-title">
        <div class="public-dashboard-copy">
            <p class="public-kicker">Public GTM signal proof</p>
            <h1 id="public-home-title">Johanna Fan</h1>
            <p class="public-lede">
                A public-safe view of how messy market, customer, and pipeline signals become
                structured evidence, reviewable judgment, and guarded next action.
            </p>
        </div>

        <aside class="public-governance-card" aria-label="Public data boundary">
            <span>Data boundary</span>
            <strong>No raw applications, outreach, company records, private notes, or HubSpot data.</strong>
            <p>
                This page uses sanitized aggregates and projection rows only. The private cockpit stays behind auth.
            </p>
        </aside>
    </section>

    <section class="public-kpi-strip" aria-label="Public-safe proof metrics" data-testid="public-kpi-strip">
        @foreach (var metric in Metrics)
        {
            <article class="public-kpi">
                <span>@metric.Label</span>
                <strong>@metric.Value</strong>
                <p>@metric.Detail</p>
            </article>
        }
    </section>

    <section id="proof" class="public-dashboard-grid" aria-labelledby="public-proof-title">
        <div class="public-panel public-chart-panel" data-testid="public-proof-chart">
            <div class="public-section-head">
                <p class="public-kicker">Pipeline proof</p>
                <h2 id="public-proof-title">Sanitized signal-to-decision flow</h2>
                <p>
                    Aggregated counts show how candidate proof is managed as an operating pipeline,
                    without exposing source rows or private systems.
                </p>
            </div>

            <TelerikChart Height="310px">
                <ChartSeriesItems>
                    <ChartSeries Type="@ChartSeriesType.Column"
                                 Data="@StageAggregates"
                                 Field="@nameof(PipelineAggregate.SignalVolume)"
                                 CategoryField="@nameof(PipelineAggregate.Stage)"
                                 Name="Signal volume" />
                    <ChartSeries Type="@ChartSeriesType.Line"
                                 Data="@StageAggregates"
                                 Field="@nameof(PipelineAggregate.ReviewedItems)"
                                 CategoryField="@nameof(PipelineAggregate.Stage)"
                                 Name="Human-reviewed items" />
                </ChartSeriesItems>
                <ChartValueAxes>
                    <ChartValueAxis Min="0">
                        <ChartValueAxisLabels Format="{0}" />
                    </ChartValueAxis>
                </ChartValueAxes>
                <ChartLegend Position="@ChartLegendPosition.Bottom" Visible="true" />
            </TelerikChart>
        </div>

        <aside class="public-panel public-detail-panel" data-testid="public-proof-detail" aria-labelledby="public-detail-title">
            <div class="public-section-head">
                <p class="public-kicker">Selected proof row</p>
                <h2 id="public-detail-title">@SelectedProof.Theme</h2>
                <p>@SelectedProof.PublicEvidence</p>
            </div>

            <dl class="public-detail-list">
                <div>
                    <dt>Decision signal</dt>
                    <dd>@SelectedProof.Decision</dd>
                </div>
                <div>
                    <dt>Public status</dt>
                    <dd><span class="public-status @StatusClass(SelectedProof.Status)">@SelectedProof.Status</span></dd>
                </div>
                <div>
                    <dt>Next human review</dt>
                    <dd>@SelectedProof.NextReview</dd>
                </div>
                <div>
                    <dt>Confidence</dt>
                    <dd>@SelectedProof.Confidence</dd>
                </div>
            </dl>
        </aside>
    </section>

    <section class="public-panel public-grid-panel" aria-labelledby="public-grid-title" data-testid="public-proof-grid">
        <div class="public-section-head">
            <p class="public-kicker">Public-safe grid</p>
            <h2 id="public-grid-title">Inspectable proof rows, not private records</h2>
            <p>
                Rows describe reusable work patterns and judgment surfaces. Select a row to inspect the public detail panel.
            </p>
        </div>

        <TelerikGrid Data="@ProofRows"
                     Height="360px"
                     Sortable="true"
                     Resizable="true"
                     SelectionMode="@GridSelectionMode.Single"
                     SelectedItems="@SelectedProofRows"
                     OnRowClick="@OnProofRowClick">
            <GridColumns>
                <GridColumn Field="@nameof(PublicProofRow.Theme)" Title="Proof Theme" Width="230px">
                    <Template>
                        @{
                            var row = (PublicProofRow)context;
                        }
                        <div class="public-grid-title">
                            <strong>@row.Theme</strong>
                            <span>@row.Scope</span>
                        </div>
                    </Template>
                </GridColumn>
                <GridColumn Field="@nameof(PublicProofRow.Decision)" Title="Decision Signal" Width="220px" />
                <GridColumn Field="@nameof(PublicProofRow.Status)" Title="Public Status" Width="150px">
                    <Template>
                        @{
                            var row = (PublicProofRow)context;
                        }
                        <span class="public-status @StatusClass(row.Status)">@row.Status</span>
                    </Template>
                </GridColumn>
                <GridColumn Field="@nameof(PublicProofRow.Confidence)" Title="Confidence" Width="130px" />
                <GridColumn Field="@nameof(PublicProofRow.NextReview)" Title="Next Review" Width="280px" />
            </GridColumns>
        </TelerikGrid>
    </section>

    <section id="workflow" class="public-panel public-gantt-panel" aria-labelledby="public-gantt-title" data-testid="public-proof-gantt">
        <div class="public-section-head">
            <p class="public-kicker">Timeline proof</p>
            <h2 id="public-gantt-title">Public milestone track for the signal workflow</h2>
            <p>
                The timeline shows how the proof system moves from signal intake through protected writeback.
                Dates are illustrative milestones, not private application history.
            </p>
        </div>

        <TelerikGantt Data="@TimelineItems"
                      Height="360px"
                      Width="100%"
                      IdField="@nameof(PublicTimelineItem.Id)"
                      ParentIdField="@nameof(PublicTimelineItem.ParentId)"
                      TitleField="@nameof(PublicTimelineItem.Title)"
                      StartField="@nameof(PublicTimelineItem.Start)"
                      EndField="@nameof(PublicTimelineItem.End)"
                      PercentCompleteField="@nameof(PublicTimelineItem.PercentComplete)"
                      View="@GanttView.Month"
                      TreeListWidth="360px"
                      ColumnResizable="true"
                      Navigable="true"
                      ShowTooltip="true">
            <GanttViews>
                <GanttMonthView />
            </GanttViews>
            <GanttColumns>
                <GanttColumn Field="@nameof(PublicTimelineItem.Title)" Title="Proof Milestone" Expandable="true" Width="220px" />
                <GanttColumn Field="@nameof(PublicTimelineItem.SignalSurface)" Title="Signal Surface" Width="150px" />
                <GanttColumn Field="@nameof(PublicTimelineItem.ReviewGate)" Title="Review Gate" Width="170px" />
            </GanttColumns>
        </TelerikGantt>
    </section>
</main>

@code {
    private static readonly IReadOnlyList<PublicMetric> Metrics =
    [
        new("Signal pool", "20k+", "Sanitized opportunity, market, and customer signals considered at aggregate level."),
        new("Decision pipeline", "370+", "Structured judgment records reduced into public-safe themes and stages."),
        new("Applied workflow", "280+", "Action lifecycle represented as counts and gates, not raw application detail."),
        new("Writeback policy", "0 auto-writes", "Private systems remain human-gated behind authenticated routes.")
    ];

    private static readonly IReadOnlyList<PipelineAggregate> StageAggregates =
    [
        new("Capture", 128, 92),
        new("Normalize", 96, 84),
        new("Score", 72, 66),
        new("Review", 48, 44),
        new("Handoff", 28, 28)
    ];

    private static readonly IReadOnlyList<PublicProofRow> ProofRows =
    [
        new(
            "GTM operations lane",
            "Role and market signals grouped into repeatable operating pools.",
            "Pool fit, sponsor risk, and proof density become comparable decision fields.",
            "Ready",
            "High",
            "Refresh public aggregate after each verified private run.",
            "Segmentation"),
        new(
            "Marketing signal analytics",
            "Campaign, lifecycle, and customer-language evidence summarized without source records.",
            "Best public proof comes from explaining the decision logic, not showing the private row.",
            "Ready",
            "High",
            "Keep one concise public example per proof theme.",
            "Analytics"),
        new(
            "CRM handoff hygiene",
            "CRM readiness is represented as policy states and review counts only.",
            "Unsafe or unclear writeback remains blocked until a human confirms context.",
            "Guarded",
            "Medium",
            "Show proposal quality, not HubSpot record contents.",
            "Governance"),
        new(
            "Interview proof packaging",
            "Private work products are translated into short, inspectable operating claims.",
            "A hiring manager should see the loop: signal, evidence, judgment, next action.",
            "Ready",
            "High",
            "Pair each claim with a public-safe evidence category.",
            "Narrative"),
        new(
            "Human approval boundary",
            "Assistant outputs are treated as drafts until reviewed and explicitly accepted.",
            "The strongest proof is a visible boundary between analysis and writeback.",
            "Review gate",
            "High",
            "Keep private routes authenticated and public routes source-redacted.",
            "Safety")
    ];

    private static readonly IReadOnlyList<PublicTimelineItem> TimelineItems =
    [
        new(1, null, "Signal intake model", "Research", "Source boundary", new DateTime(2026, 6, 1), new DateTime(2026, 6, 8), 1),
        new(2, null, "Evidence normalization", "Pipeline", "Human review", new DateTime(2026, 6, 6), new DateTime(2026, 6, 15), 0.9),
        new(3, null, "Public proof projection", "Portfolio", "Redaction check", new DateTime(2026, 6, 12), new DateTime(2026, 6, 22), 0.75),
        new(4, null, "Dashboard proof surface", "Telerik UI", "Browser smoke", new DateTime(2026, 6, 20), new DateTime(2026, 6, 29), 0.65),
        new(5, null, "Protected cockpit handoff", "Private app", "Basic Auth", new DateTime(2026, 6, 24), new DateTime(2026, 7, 3), 0.55)
    ];

    private PublicProofRow SelectedProof { get; set; } = ProofRows[0];

    private IEnumerable<PublicProofRow> SelectedProofRows => [SelectedProof];

    private Task OnProofRowClick(GridRowClickEventArgs args)
    {
        if (args.Item is PublicProofRow selected)
        {
            SelectedProof = selected;
        }

        return Task.CompletedTask;
    }

    private static string StatusClass(string status) => status switch
    {
        "Ready" => "public-status-ready",
        "Guarded" => "public-status-guarded",
        "Review gate" => "public-status-review",
        _ => "public-status-neutral"
    };

    private sealed record PublicMetric(string Label, string Value, string Detail);

    private sealed record PipelineAggregate(string Stage, int SignalVolume, int ReviewedItems);

    private sealed record PublicProofRow(
        string Theme,
        string PublicEvidence,
        string Decision,
        string Status,
        string Confidence,
        string NextReview,
        string Scope);

    private sealed record PublicTimelineItem(
        int Id,
        int? ParentId,
        string Title,
        string SignalSurface,
        string ReviewGate,
        DateTime Start,
        DateTime End,
        double PercentComplete);
}

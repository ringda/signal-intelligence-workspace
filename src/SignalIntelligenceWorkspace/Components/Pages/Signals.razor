@page "/signals"
@implements IDisposable
@inject WorkspaceState State
@inject ScenarioPack Scenario
@inject IStringLocalizer<Ui> L

<PageTitle>@L["Nav.Signals"] | @L["App.Name"]</PageTitle>

<h2>@L["Signals.Title"]</h2>
<p class="muted">@L["Signals.Subtitle"]</p>

@if (State.AppliedThemeFilter is not null)
{
    <div class="ai-filter-chip">
        <span>@L["Signals.FilterActive"] <strong>@State.AppliedThemeFilter</strong></span>
        <TelerikButton FillMode="@ThemeConstants.Button.FillMode.Flat"
                       Size="@ThemeConstants.Button.Size.Small"
                       OnClick="@(() => State.ClearThemeFilter())">@L["Action.Clear"]</TelerikButton>
    </div>
}

<TelerikGrid Data="@State.FilteredThemes" Sortable="true" FilterMode="@GridFilterMode.FilterMenu">
    <GridColumns>
        <GridColumn Field="@nameof(ThemeRow.Theme)" Title="@(L["Col.Theme"])" />
        <GridColumn Field="@nameof(ThemeRow.Segment)" Title="@(L["Col.MarketSegment"])" Width="180px" />
        <GridColumn Field="@nameof(ThemeRow.Frequency)" Title="@(L["Col.Frequency"])" Width="120px" />
        <GridColumn Field="@nameof(ThemeRow.Confidence)" Title="@(L["Col.Confidence"])" Width="130px" />
        <GridColumn Field="@nameof(ThemeRow.Example)" Title="@(L["Col.Example"])" />
        <GridColumn Field="@nameof(ThemeRow.SuggestedUse)" Title="@(L["Col.SuggestedUse"])" />
        <GridColumn Field="@nameof(ThemeRow.ReviewStatus)" Title="@(L["Col.ReviewStatus"])" Width="140px">
            <Template>
                @L.State(((ThemeRow)context).ReviewStatus)
            </Template>
        </GridColumn>
    </GridColumns>
</TelerikGrid>

<h3 class="section-title">@L["Signals.ChartTitle"]</h3>
<TelerikChart Height="320px">
    <ChartSeriesItems>
        <ChartSeries Type="@ChartSeriesType.Column"
                     Data="@SegmentTotals"
                     Field="@nameof(SegmentTotal.Mentions)"
                     CategoryField="@nameof(SegmentTotal.Segment)"
                     Name="@(L["Col.Frequency"])" />
    </ChartSeriesItems>
</TelerikChart>

@code {
    private List<SegmentTotal> SegmentTotals => Scenario.Segments
        .Select(s => new SegmentTotal(
            s,
            Scenario.Themes.Where(t => t.Segment == s).Sum(t => t.Frequency)))
        .ToList();

    public sealed record SegmentTotal(string Segment, int Mentions);

    protected override void OnInitialized() => State.Changed += OnStateChanged;

    private void OnStateChanged() => InvokeAsync(StateHasChanged);

    public void Dispose() => State.Changed -= OnStateChanged;
}

@page "/governance"
@implements IDisposable
@inject WorkspaceState State
@inject ScenarioPack Scenario
@inject IStringLocalizer<Ui> L

<PageTitle>@L["Nav.Governance"] | @L["App.Name"]</PageTitle>

<h2>@L["Governance.Title"]</h2>
<p class="muted">@L["Governance.Subtitle"]</p>

<TelerikAIPrompt OnPromptRequest="@OnPromptRequest" PromptSuggestions="@Suggestions" />

<TelerikDialog @bind-Visible="@DialogVisible" Title="@(L["Governance.DialogTitle"])" Width="560px">
    <DialogContent>
        <p>@L["Governance.DialogBody"]</p>
        <pre class="command-json">@PendingJson</pre>
    </DialogContent>
    <DialogButtons>
        <TelerikButton OnClick="@Approve">@L["Action.Approve"]</TelerikButton>
        <TelerikButton OnClick="@Reject">@L["Action.Reject"]</TelerikButton>
    </DialogButtons>
</TelerikDialog>

<h3 class="section-title">@L["Governance.ReviewQueue"]</h3>
@if (State.ReviewItems.Count == 0)
{
    <p class="muted">@L["Governance.ReviewQueueEmpty"]</p>
}
else
{
    @foreach (var item in State.ReviewItems)
    {
        <TelerikCard Class="review-card">
            <CardHeader>
                <CardTitle>@item.Title</CardTitle>
                <CardSubTitle>
                    <span class="badge @BadgeClass(item.State)">@L.State(item.State)</span>
                    <span class="muted"> · @item.SourceCommand · @item.CreatedAt</span>
                </CardSubTitle>
            </CardHeader>
            <CardBody>
                <pre class="draft-body">@item.Body</pre>
            </CardBody>
            <CardActions>
                <TelerikButton OnClick="@(() => State.SetReviewState(item.Id, ReviewState.Approved))"
                               Enabled="@IsActionable(item.State)">@L["Action.Approve"]</TelerikButton>
                <TelerikButton OnClick="@(() => State.SetReviewState(item.Id, ReviewState.Rejected))"
                               Enabled="@IsActionable(item.State)">@L["Action.Reject"]</TelerikButton>
            </CardActions>
        </TelerikCard>
    }
}

<h3 class="section-title">@L["Governance.AuditLog"]</h3>
<p class="muted">@L["Governance.AuditSubtitle"]</p>
<TelerikGrid Data="@State.AuditLog.ToList()" Height="340px">
    <GridColumns>
        <GridColumn Field="@nameof(AuditEntry.Timestamp)" Title="@(L["Col.Time"])" Width="100px" />
        <GridColumn Field="@nameof(AuditEntry.Role)" Title="@(L["Col.Role"])" Width="170px" />
        <GridColumn Field="@nameof(AuditEntry.Prompt)" Title="@(L["Col.Prompt"])" />
        <GridColumn Field="@nameof(AuditEntry.GeneratedCommand)" Title="@(L["Col.GeneratedCommand"])" />
        <GridColumn Field="@nameof(AuditEntry.Decision)" Title="@(L["Col.Decision"])" Width="210px" />
        <GridColumn Field="@nameof(AuditEntry.Reason)" Title="@(L["Col.Reason"])" />
    </GridColumns>
</TelerikGrid>

@code {
    private bool DialogVisible;
    private string PendingJson = string.Empty;

    private List<string> Suggestions => Scenario.DemoPrompts.ToList();

    private void OnPromptRequest(AIPromptPromptRequestEventArgs args)
    {
        var result = State.SubmitPrompt(args.Prompt);
        switch (result.Outcome)
        {
            case ParseOutcome.Allowed:
                PendingJson = CommandFormatter.ToJson(result.Command!);
                DialogVisible = true;
                args.Output = L["Governance.OutputApproved"];
                break;
            case ParseOutcome.Forbidden:
                args.Output = $"Blocked by policy ({result.BlockedRuleName}): {result.Reason}";
                break;
            default:
                args.Output = result.Reason ?? string.Empty;
                break;
        }
    }

    private void Approve()
    {
        State.ApprovePending();
        DialogVisible = false;
    }

    private void Reject()
    {
        State.RejectPending();
        DialogVisible = false;
    }

    private static bool IsActionable(ReviewState state) =>
        state is ReviewState.Drafted or ReviewState.NeedsReview;

    private static string BadgeClass(ReviewState state) => state switch
    {
        ReviewState.Drafted => "badge-drafted",
        ReviewState.NeedsReview => "badge-needsreview",
        ReviewState.Approved => "badge-approved",
        _ => "badge-rejected",
    };

    protected override void OnInitialized() => State.Changed += OnStateChanged;

    private void OnStateChanged() => InvokeAsync(StateHasChanged);

    public void Dispose() => State.Changed -= OnStateChanged;
}

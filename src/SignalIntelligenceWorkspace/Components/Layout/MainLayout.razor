@inherits LayoutComponentBase
@layout TelerikLayout
@inject WorkspaceState State
@inject IStringLocalizer<Ui> L
@inject NavigationManager Nav
@using System.Globalization

<div class="topbar">
    <TelerikButton Icon="@SvgIcon.Menu"
                   FillMode="@ThemeConstants.Button.FillMode.Flat"
                   OnClick="@ToggleDrawerAsync"
                   Title="@L["Action.ToggleNav"]" />
    <div class="topbar-titles">
        <span class="app-name">@L["App.Name"]</span>
        <span class="scenario-name">@L["App.Subtitle"]</span>
    </div>
    <span class="topbar-spacer"></span>
    <div class="lang-switch">
        <a class="lang-link @(IsEn ? "lang-active" : "")" href="@CultureUrl("en")">EN</a>
        <span class="lang-sep">/</span>
        <a class="lang-link @(IsEn ? "" : "lang-active")" href="@CultureUrl("zh-Hant")">繁中</a>
    </div>
    <TelerikButton OnClick="@(() => State.ResetSession())" Title="@L["Action.ResetSession.Title"]">
        @L["Action.ResetSession"]
    </TelerikButton>
</div>

<TelerikDrawer @ref="@DrawerRef"
               Data="@NavItems"
               Expanded="@DrawerExpanded"
               ExpandedChanged="@OnDrawerExpandedChangedAsync"
               MiniMode="true"
               Mode="@DrawerMode.Push">
    <Template>
        <ul role="menubar" aria-orientation="vertical" class="k-drawer-items app-drawer-items">
            @foreach (var item in NavItems)
            {
                <li @key="@item.Url" @onclick:stopPropagation>
                    <NavLink href="@item.Url"
                             Match="@item.Match"
                             class="k-drawer-item app-drawer-item"
                             ActiveClass="k-state-selected k-selected"
                             title="@item.Text"
                             role="menuitem"
                             aria-label="@item.Text">
                        <TelerikSvgIcon Icon="@item.Icon" />
                        <span class="k-item-text">@item.Text</span>
                    </NavLink>
                </li>
            }
        </ul>
    </Template>
    <DrawerContent>
        <div class="page-body">
            @Body
        </div>
    </DrawerContent>
</TelerikDrawer>

<div id="blazor-error-ui">
    An unhandled error has occurred.
    <a href="" class="reload">Reload</a>
    <a class="dismiss">🗙</a>
</div>

@code {
    private TelerikDrawer<NavItem>? DrawerRef { get; set; }
    private bool DrawerExpanded { get; set; }

    private bool IsEn => CultureInfo.CurrentUICulture.TwoLetterISOLanguageName == "en";

    private List<NavItem> NavItems => new()
    {
        new NavItem { Text = L["Nav.Cockpit"], Icon = SvgIcon.Home, Url = "/", Match = NavLinkMatch.All },
        new NavItem { Text = L["Nav.ApplicationIntelligence"], Icon = SvgIcon.ChartLineMarkers, Url = "/application-intelligence" },
        new NavItem { Text = L["Nav.HubSpot"], Icon = SvgIcon.Folder, Url = "/hubspot" },
        new NavItem { Text = L["Nav.Governance"], Icon = SvgIcon.Sparkles, Url = "/governance" },
        new NavItem { Text = L["Nav.Signals"], Icon = SvgIcon.Eye, Url = "/signals" },
        new NavItem { Text = L["Nav.Resources"], Icon = SvgIcon.Folder, Url = "/resources" },
    };

    private string CultureUrl(string culture)
    {
        var current = Nav.ToBaseRelativePath(Nav.Uri);
        var redirect = Uri.EscapeDataString("/" + current);
        return $"/culture/set?culture={culture}&redirectUri={redirect}";
    }

    private async Task ToggleDrawerAsync()
    {
        if (DrawerRef is null)
        {
            DrawerExpanded = !DrawerExpanded;
            return;
        }

        if (DrawerExpanded)
        {
            await DrawerRef.CollapseAsync();
        }
        else
        {
            await DrawerRef.ExpandAsync();
        }
    }

    private Task OnDrawerExpandedChangedAsync(bool expanded)
    {
        DrawerExpanded = expanded;
        return Task.CompletedTask;
    }

    public class NavItem
    {
        public string Text { get; set; } = string.Empty;
        public ISvgIcon? Icon { get; set; }
        public string Url { get; set; } = string.Empty;
        public NavLinkMatch Match { get; set; } = NavLinkMatch.Prefix;
    }
}
